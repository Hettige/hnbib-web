---
import type { SiteSettings } from '../lib/strapi';

interface Props {
  base: string;
  settings?: SiteSettings | null;
}
const { base, settings } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner section-inner">

    <!-- Brand column -->
    <div class="footer-brand">
      <a href={base} class="nav-logo">
        <img src={`${base}assets/images/logo/hnb-inv-logo.webp`} alt="HNB Investment Bank" />
      </a>
      <p class="footer-tagline">
        {settings?.tagline ?? "Sri Lanka's premier investment bank."}
      </p>
      <!-- Social -->
      {settings?.linkedIn && (
        <a href={settings.linkedIn} class="footer-social" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      )}
    </div>

    <!-- Services column -->
    <div class="footer-col">
      <h3 class="footer-heading">Services</h3>
      <ul class="footer-links">
        <li><a href={`${base}hnb-stockbrokers/`}>HNB Stockbrokers</a></li>
        <li><a href={`${base}hnb-securities/`}>HNB Securities</a></li>
        <li><a href={`${base}corporate-finance/`}>Corporate Finance</a></li>
        <li><a href={`${base}lanka-ventures-lvl/`}>Lanka Ventures</a></li>
      </ul>
    </div>

    <!-- Company column -->
    <div class="footer-col">
      <h3 class="footer-heading">Company</h3>
      <ul class="footer-links">
        <li><a href={`${base}about-us/`}>About Us</a></li>
        <li><a href={`${base}team/`}>Our Team</a></li>
        <li><a href={`${base}news/`}>Insights</a></li>
        <li><a href={`${base}corporate-finance/`}>Track Record</a></li>
      </ul>
    </div>

    <!-- Contact column -->
    <div class="footer-col">
      <h3 class="footer-heading">Contact</h3>
      <address class="footer-address">
        {settings?.address && <p>{settings.address}</p>}
        {settings?.phone   && <p><a href={`tel:${settings.phone}`}>{settings.phone}</a></p>}
        {settings?.email   && <p><a href={`mailto:${settings.email}`}>{settings.email}</a></p>}
      </address>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="section-inner footer-bottom-inner">
      <p class="footer-copy">
        &copy; {year} {settings?.footerCopyright ?? 'HNB Investment Bank Limited. All rights reserved.'}
      </p>
      <p class="footer-reg">
        {settings?.regulatedBy && `Regulated by ${settings.regulatedBy}.`}
        {settings?.cseStatus   && ` ${settings.cseStatus}.`}
        {settings?.cbslStatus  && ` ${settings.cbslStatus}.`}
      </p>
    </div>
  </div>
</footer>
