---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticles, formatDate, imgUrl } from '../../lib/strapi';

const base = import.meta.env.BASE_URL;
const articles = await getArticles();

// Serialise for client-side pagination JS
const POSTS = articles.map(a => ({
  slug:    a.slug,
  title:   a.title,
  cat:     a.category,
  excerpt: a.excerpt,
  date:    formatDate(a.publishDate),
  read:    a.readTime ?? '3 min read',
  img:     a.featuredImage ? imgUrl(a.featuredImage, 'medium') : '',
  imgAlt:  a.featuredImage?.alternativeText ?? a.title,
}));

// Hardcoded fallback posts (used when Strapi returns nothing)
const FALLBACK_POSTS = [
  { slug:'aspi-22000', title:'ASPI Crosses 22,000 — What the Recovery Means for Equity Investors in 2026', cat:'Market Commentary', excerpt:'After a sustained period of macroeconomic pressure, Sri Lanka\'s equity market is signalling a clear inflection. Our Head of Research unpacks the drivers.', date:'15 May 2026', read:'5 min read', img:'', imgAlt:'' },
  { slug:'tbill-yields-ease', title:'T-Bill Yields Ease for Third Consecutive Auction', cat:'Market Commentary', excerpt:'Three successive auction results show softening yields across all T-Bill tenors, signalling easing monetary conditions.', date:'12 May 2026', read:'3 min read', img:'', imgAlt:'' },
  { slug:'hnb-debenture', title:'HNB Investment Bank Completes LKR 7.5 Bn Debenture for HNB PLC', cat:'Corporate Finance', excerpt:'Acting as Lead Manager, HNB Investment Bank successfully closed a LKR 7.5 billion listed debenture for Hatton National Bank PLC.', date:'8 May 2026', read:'4 min read', img:'', imgAlt:'' },
  { slug:'cse-banks-q1', title:'CSE Banks Sector — Q1 2026 Review', cat:'Market Commentary', excerpt:'A sector-level review of listed banking stocks. Earnings resilience, credit quality, and re-rating catalysts.', date:'1 May 2026', read:'6 min read', img:'', imgAlt:'' },
  { slug:'alpha-fire-ipo', title:'Alpha Fire Services IPO — Subscription Opens 20 May', cat:'Corporate Finance', excerpt:'HNB Investment Bank is acting as Manager for the Alpha Fire Services IPO, opening for public subscription from 20 May 2026.', date:'18 Apr 2026', read:'3 min read', img:'', imgAlt:'' },
  { slug:'lvl-energy-results', title:'LVL Energy Fund Posts Improved Q1 Results', cat:'Company News', excerpt:'LVL Energy Fund PLC reported improved profitability in Q1 2026, driven by higher energy tariffs and improved capacity utilisation.', date:'10 Apr 2026', read:'3 min read', img:'', imgAlt:'' },
];
---

<BaseLayout
  title="Insights &amp; Newsroom — HNB Investment Bank"
  description="Research, deal announcements, and company news — from our desk to yours."
>

<div class="page-header"><div class="page-header-inner">
  <div class="page-header-eyebrow">Insights &amp; Newsroom</div>
  <h1 class="page-header-h1">Market intelligence from HNB Investment Bank.</h1>
  <p class="page-header-lead">Research, deal announcements, and company news — from our desk to yours.</p>
</div></div>

<main class="page-body">
<section class="section-pad">
  <div class="section-inner" style="max-width:100%;padding:0">

    <!-- Filter tabs -->
    <div class="news-filters" role="tablist" aria-label="Filter articles by category">
      <button class="news-filter-btn active" data-cat="all" role="tab" aria-selected="true">All</button>
      <button class="news-filter-btn" data-cat="Market Commentary" role="tab" aria-selected="false">Market Commentary</button>
      <button class="news-filter-btn" data-cat="Corporate Finance" role="tab" aria-selected="false">Corporate Finance</button>
      <button class="news-filter-btn" data-cat="Partnership" role="tab" aria-selected="false">Partnership</button>
      <button class="news-filter-btn" data-cat="Company News" role="tab" aria-selected="false">Company News</button>
    </div>

    <!-- Result count -->
    <div class="news-count" id="news-count" aria-live="polite"></div>

    <!-- Dynamic grid (filled by JS) -->
    <div class="news-grid-wrap" id="news-grid"></div>

    <!-- Pagination -->
    <div class="news-pagination" id="news-pagination"></div>

  </div>
</section>
</main>

</BaseLayout>

<script is:inline define:vars={{ POSTS, FALLBACK_POSTS, base }}>
(function () {
  'use strict';

  var ALL_POSTS = POSTS.length > 0 ? POSTS : FALLBACK_POSTS;
  var PER_PAGE  = 4;
  var currentPage = 1;
  var currentCat  = 'all';

  function filtered() {
    if (currentCat === 'all') return ALL_POSTS;
    return ALL_POSTS.filter(function(p) { return p.cat === currentCat; });
  }

  function featuredHTML(p) {
    var imgHtml = p.img
      ? '<img src="' + p.img + '" alt="' + escHtml(p.imgAlt) + '" loading="eager" />'
      : '<div style="width:100%;height:100%;background:oklch(0.36 0.14 242)"></div>';
    return '<a href="' + base + 'news/' + p.slug + '/" class="nc-featured" data-category="' + escHtml(p.cat) + '">' +
      '<div class="nc-featured-img">' + imgHtml + '<div class="nc-featured-img-overlay"></div><div class="nc-featured-badge">Featured</div></div>' +
      '<div class="nc-featured-body">' +
        '<span class="nc-featured-tag">' + escHtml(p.cat) + '</span>' +
        '<div class="nc-featured-title">' + escHtml(p.title) + '</div>' +
        '<div class="nc-featured-excerpt">' + escHtml(p.excerpt) + '</div>' +
        '<div class="nc-featured-meta">' + escHtml(p.date) + ' &middot; ' + escHtml(p.read) + '</div>' +
        '<div class="nc-featured-cta">Read article <span aria-hidden="true">&rarr;</span></div>' +
      '</div>' +
    '</a>';
  }

  function cardHTML(p) {
    var imgHtml = p.img
      ? '<img src="' + p.img + '" alt="' + escHtml(p.imgAlt) + '" loading="lazy" />'
      : '<div style="width:100%;height:100%;background:oklch(0.96 0.008 242)"></div>';
    return '<a href="' + base + 'news/' + p.slug + '/" class="nc" data-category="' + escHtml(p.cat) + '">' +
      '<div class="nc-img">' + imgHtml + '<div class="nc-img-overlay"></div></div>' +
      '<div class="nc-body">' +
        '<div class="nc-tag">' + escHtml(p.cat) + '</div>' +
        '<div class="nc-title">' + escHtml(p.title) + '</div>' +
        '<div class="nc-footer"><span class="nc-meta">' + escHtml(p.date) + ' &middot; ' + escHtml(p.read) + '</span><span class="nc-read">Read <span aria-hidden="true">&rarr;</span></span></div>' +
      '</div>' +
    '</a>';
  }

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function render(scrollUp) {
    var posts  = filtered();
    var total  = posts.length;
    var pages  = Math.max(1, Math.ceil(total / PER_PAGE));
    if (currentPage > pages) currentPage = pages;

    var start = (currentPage - 1) * PER_PAGE;
    var slice = posts.slice(start, start + PER_PAGE);

    var html = '';
    if (total === 0) {
      html = '<div class="news-empty"><svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 9v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><p>No articles yet. Check back soon.</p></div>';
    } else {
      // Page 1 shows first as featured, rest as grid
      // Other pages show all as grid
      if (currentPage === 1 && slice.length > 0) {
        html += featuredHTML(slice[0]);
        var rest = slice.slice(1);
        if (rest.length > 0) {
          html += '<div class="news-cards-grid">' + rest.map(cardHTML).join('') + '</div>';
        }
      } else {
        html += '<div class="news-cards-grid">' + slice.map(cardHTML).join('') + '</div>';
      }
    }

    var grid = document.getElementById('news-grid');
    if (grid) grid.innerHTML = html;

    var count = document.getElementById('news-count');
    if (count) {
      count.textContent = total + ' article' + (total !== 1 ? 's' : '') +
        (currentCat !== 'all' ? ' in ' + currentCat : '');
    }

    renderPagination(pages);

    if (scrollUp) {
      var el = document.getElementById('news-grid');
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  function renderPagination(totalPages) {
    var pag = document.getElementById('news-pagination');
    if (!pag) return;
    if (totalPages <= 1) { pag.innerHTML = ''; return; }

    var html = '<div class="pag-inner">';
    html += '<button class="pag-btn' + (currentPage === 1 ? ' disabled' : '') + '" id="pag-prev" aria-label="Previous page">&larr; Prev</button>';
    for (var i = 1; i <= totalPages; i++) {
      html += '<button class="pag-num' + (i === currentPage ? ' active' : '') + '" data-page="' + i + '">' + i + '</button>';
    }
    html += '<button class="pag-btn' + (currentPage === totalPages ? ' disabled' : '') + '" id="pag-next" aria-label="Next page">Next &rarr;</button>';
    html += '</div>';
    pag.innerHTML = html;

    var prev = document.getElementById('pag-prev');
    var next = document.getElementById('pag-next');
    if (prev) prev.addEventListener('click', function() {
      if (currentPage > 1) { currentPage--; render(true); }
    });
    if (next) next.addEventListener('click', function() {
      if (currentPage < totalPages) { currentPage++; render(true); }
    });
    pag.querySelectorAll('.pag-num').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var p = parseInt(btn.getAttribute('data-page') || '1', 10);
        if (p !== currentPage) { currentPage = p; render(true); }
      });
    });
  }

  // Filter buttons
  document.querySelectorAll('.news-filter-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.news-filter-btn').forEach(function(b) {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      currentCat  = btn.getAttribute('data-cat') || 'all';
      currentPage = 1;
      render(false);
    });
  });

  // Initial render
  render(false);
})();
</script>

<style>
.news-filters {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: var(--sp-m);
  padding-bottom: var(--sp-m);
  border-bottom: 1px solid var(--line);
}
.news-filter-btn {
  padding: 8px 20px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  border: 1.5px solid var(--line);
  border-radius: 100px;
  background: var(--card);
  color: var(--ink-2);
  cursor: pointer;
  font-family: var(--font);
  transition: all var(--dur-fast);
  white-space: nowrap;
}
.news-filter-btn:hover { border-color: var(--primary); color: var(--primary); }
.news-filter-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); }

.news-count {
  font-size: 13px;
  color: var(--ink-3);
  margin-bottom: var(--sp-m);
  min-height: 20px;
}

.news-grid-wrap { transition: opacity .22s ease; }

.nc-featured {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: calc(var(--radius) * 2);
  overflow: hidden;
  margin-bottom: var(--sp-m);
  min-height: 340px;
  text-decoration: none;
  color: inherit;
  transition: box-shadow var(--dur-mid), transform var(--dur-mid);
}
.nc-featured:hover {
  box-shadow: 0 16px 48px oklch(0.42 0.14 242/.13);
  transform: translateY(-2px);
}
.nc-featured-img {
  position: relative;
  overflow: hidden;
  min-height: 300px;
}
.nc-featured-img img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .8s var(--ease-out);
}
.nc-featured:hover .nc-featured-img img { transform: scale(1.05); }
.nc-featured-img-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, oklch(0.19 0.013 250/.5) 0%, transparent 60%);
  pointer-events: none;
}
.nc-featured-badge {
  position: absolute;
  top: 20px;
  left: 20px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  background: var(--accent);
  color: #fff;
  padding: 5px 12px;
  border-radius: 100px;
}
.nc-featured-body {
  padding: var(--sp-l);
  display: flex;
  flex-direction: column;
  gap: 14px;
  justify-content: center;
}
.nc-featured-tag {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--accent-d);
  display: inline-block;
  background: oklch(0.62 0.16 141/.10);
  padding: 4px 12px;
  border-radius: 100px;
  width: fit-content;
}
.nc-featured-title {
  font-size: clamp(17px, 2.2vw, 24px);
  font-weight: 800;
  color: var(--ink);
  line-height: 1.25;
}
.nc-featured-excerpt {
  font-size: 14px;
  color: var(--ink-2);
  line-height: 1.7;
}
.nc-featured-meta {
  font-size: 12px;
  color: var(--ink-3);
  display: flex;
  align-items: center;
  gap: 8px;
}
.nc-featured-meta::before {
  content: '';
  display: inline-block;
  width: 3px;
  height: 14px;
  background: var(--accent);
  border-radius: 2px;
}
.nc-featured-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  background: var(--primary);
  padding: 10px 20px;
  border-radius: var(--radius);
  width: fit-content;
  margin-top: 4px;
  transition: background var(--dur-fast), gap var(--dur-fast);
}
.nc-featured:hover .nc-featured-cta { background: var(--primary-d); gap: 12px; }

.news-cards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.nc {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: calc(var(--radius) * 2);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  transition: box-shadow var(--dur-mid), transform var(--dur-mid);
}
.nc:hover {
  box-shadow: 0 10px 32px oklch(0.42 0.14 242/.11);
  transform: translateY(-4px);
}
.nc-img {
  position: relative;
  height: 190px;
  overflow: hidden;
  background: var(--bg-2);
}
.nc-img img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .7s var(--ease-out);
}
.nc:hover .nc-img img { transform: scale(1.07); }
.nc-img-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, oklch(0.19 0.013 250/.35) 0%, transparent 55%);
  pointer-events: none;
}
.nc-body {
  padding: 20px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.nc-tag {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--primary);
}
.nc-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.35;
  flex: 1;
}
.nc-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--line);
}
.nc-meta { font-size: 11px; color: var(--ink-3); }
.nc-read {
  font-size: 12px;
  font-weight: 700;
  color: var(--primary);
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: gap var(--dur-fast);
}
.nc:hover .nc-read { gap: 8px; }

.news-empty {
  text-align: center;
  padding: var(--sp-xl) 0;
  color: var(--ink-3);
}
.news-empty svg { margin: 0 auto var(--sp-m); display: block; opacity: .3; }
.news-empty p { font-size: 15px; }

/* Pagination */
.news-pagination { margin-top: var(--sp-l); }
.pag-inner { display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap; }
.pag-btn {
  padding: 8px 20px;
  font-size: 13px;
  font-weight: 700;
  border: 1.5px solid var(--line);
  border-radius: var(--radius);
  background: var(--card);
  color: var(--primary);
  cursor: pointer;
  font-family: var(--font);
  transition: all var(--dur-fast);
}
.pag-btn:hover:not(.disabled) { border-color: var(--primary); background: var(--primary); color: #fff; }
.pag-btn.disabled { opacity: .35; cursor: not-allowed; }
.pag-num {
  width: 40px;
  height: 40px;
  font-size: 13px;
  font-weight: 700;
  border: 1.5px solid var(--line);
  border-radius: var(--radius);
  background: var(--card);
  color: var(--ink-2);
  cursor: pointer;
  font-family: var(--font);
  transition: all var(--dur-fast);
  display: flex;
  align-items: center;
  justify-content: center;
}
.pag-num:hover { border-color: var(--primary); color: var(--primary); }
.pag-num.active { background: var(--primary); border-color: var(--primary); color: #fff; }

@media (max-width: 1024px) {
  .nc-featured { grid-template-columns: 1fr 1fr; min-height: 280px; }
  .news-cards-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .nc-featured { grid-template-columns: 1fr; }
  .nc-featured-img { min-height: 220px; }
  .nc-featured-body { padding: var(--sp-m); gap: 12px; }
  .nc-featured-title { font-size: 18px; }
  .news-cards-grid { grid-template-columns: 1fr; }
  .news-filters { gap: 6px; }
  .news-filter-btn { padding: 7px 14px; font-size: 10px; }
}
</style>
