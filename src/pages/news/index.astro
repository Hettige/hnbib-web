---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticles, formatDate, imgUrl } from '../../lib/strapi';

const base = import.meta.env.BASE_URL;
const articles = await getArticles();

const categories = ['All', 'Market Commentary', 'Corporate Finance', 'Partnership', 'Company News'] as const;
---

<BaseLayout
  title="Insights - HNB Investment Bank"
  description="Market commentary, corporate finance updates, and company news from HNB Investment Bank."
>
  <!-- Page hero -->
  <div id="site-header" class="site-header page-hero-simple">
    <div class="page-hero-inner section-inner">
      <p class="overline">News &amp; Insights</p>
      <h1>HNBIB Insights</h1>
      <p class="hero-sub">Market commentary, transaction announcements, and company updates.</p>
    </div>
  </div>

  <section class="section-pad">
    <div class="section-inner">

      <!-- Category filter tabs -->
      <div class="filter-tabs" role="tablist" aria-label="Filter articles by category">
        {categories.map(cat => (
          <button
            class="filter-tab"
            data-cat={cat}
            role="tab"
            aria-selected={cat === 'All' ? 'true' : 'false'}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Article grid -->
      <div id="articles-grid" class="articles-grid">
        {articles.map((a, i) => (
          <a
            href={`${base}news/${a.slug}/`}
            class:list={['article-card', i === 0 && 'article-card--featured']}
            data-category={a.category}
          >
            <div class="ac-img">
              {a.featuredImage
                ? <img src={imgUrl(a.featuredImage, i === 0 ? 'medium' : 'small')} alt={a.featuredImage.alternativeText ?? a.title} loading={i < 3 ? 'eager' : 'lazy'} />
                : <div class="ac-img-placeholder"></div>
              }
              <span class="ac-cat">{a.category}</span>
            </div>
            <div class="ac-body">
              <p class="ac-date">{formatDate(a.publishDate)}</p>
              <h2 class="ac-title">{a.title}</h2>
              <p class="ac-excerpt">{a.excerpt}</p>
              <span class="ac-read">{a.readTime ?? '3 min read'} &rarr;</span>
            </div>
          </a>
        ))}
      </div>

      <!-- No results message (hidden by default) -->
      <p id="no-results" class="no-results" hidden>
        No articles in this category yet.
      </p>

    </div>
  </section>
</BaseLayout>

<script>
  // Category filtering (client-side, no reload)
  const tabs  = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const cards = document.querySelectorAll<HTMLElement>('.article-card');
  const noRes = document.getElementById('no-results')!;

  function filter(cat: string) {
    let visible = 0;
    cards.forEach(card => {
      const show = cat === 'All' || card.dataset.category === cat;
      card.hidden = !show;
      if (show) visible++;
    });
    noRes.hidden = visible > 0;
    tabs.forEach(t => {
      const isActive = t.dataset.cat === cat;
      t.setAttribute('aria-selected', String(isActive));
      t.classList.toggle('active', isActive);
    });
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => filter(tab.dataset.cat ?? 'All'));
  });

  // Set first tab active on load
  tabs[0]?.classList.add('active');
</script>

<style>
.page-hero-simple {
  background: linear-gradient(135deg, oklch(0.22 0.10 242), oklch(0.34 0.14 260));
  padding: var(--sp-3xl) 0 var(--sp-2xl);
  color: #fff;
}
.page-hero-inner { max-width: 640px; }
.page-hero-simple .overline { color: oklch(1 0 0 / .60); }
.page-hero-simple h1 { color: #fff; margin: var(--sp-xs) 0 var(--sp-m); }
.page-hero-simple .hero-sub { color: oklch(1 0 0 / .75); }

/* Filter tabs */
.filter-tabs {
  display: flex;
  gap: var(--sp-s);
  flex-wrap: wrap;
  margin-bottom: var(--sp-xl);
  padding-bottom: var(--sp-m);
  border-bottom: 1px solid oklch(0 0 0 / .08);
}
.filter-tab {
  background: none;
  border: 1px solid oklch(0 0 0 / .12);
  border-radius: 99px;
  padding: var(--sp-xs) var(--sp-m);
  font-family: inherit;
  font-size: 0.85rem;
  cursor: pointer;
  color: var(--text-muted);
  transition: background .15s, color .15s, border-color .15s;
}
.filter-tab.active,
.filter-tab[aria-selected="true"] {
  background: var(--primary);
  border-color: var(--primary);
  color: #fff;
}
.filter-tab:hover:not(.active) { border-color: var(--primary); color: var(--primary); }

/* Articles grid */
.articles-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-l);
}
/* Featured article spans full width */
.article-card--featured {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.article-card--featured .ac-img { aspect-ratio: 16/9; }
.article-card--featured .ac-title { font-size: 1.4rem; }

.article-card {
  text-decoration: none;
  color: inherit;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid oklch(0 0 0 / .08);
  background: #fff;
  transition: box-shadow .2s, transform .2s;
  display: flex;
  flex-direction: column;
}
.article-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px oklch(0 0 0 / .10); }
.ac-img { position: relative; aspect-ratio: 16/9; overflow: hidden; }
.ac-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .35s; }
.article-card:hover .ac-img img { transform: scale(1.04); }
.ac-img-placeholder { width: 100%; height: 100%; background: var(--bg); }
.ac-cat { position: absolute; top: var(--sp-s); left: var(--sp-s); background: var(--accent); color: #fff; font-size: 0.7rem; font-weight: 600; padding: 3px 10px; border-radius: 99px; }
.ac-body { padding: var(--sp-m); flex: 1; display: flex; flex-direction: column; }
.ac-date { font-size: 0.78rem; color: var(--text-muted); margin: 0 0 var(--sp-xs); }
.ac-title { font-size: 1rem; font-weight: 600; color: var(--primary); margin: 0 0 var(--sp-s); line-height: 1.4; }
.ac-excerpt { font-size: 0.86rem; color: var(--text-muted); margin: 0 0 auto; padding-bottom: var(--sp-m); line-height: 1.6; }
.ac-read { font-size: 0.82rem; font-weight: 600; color: var(--accent); }
.no-results { text-align: center; color: var(--text-muted); padding: var(--sp-2xl) 0; }

@media (max-width: 1024px) {
  .articles-grid { grid-template-columns: repeat(2, 1fr); }
  .article-card--featured { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  .articles-grid { grid-template-columns: 1fr; }
  .article-card--featured { grid-column: auto; }
}
</style>
