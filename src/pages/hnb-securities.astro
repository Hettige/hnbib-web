---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getRates } from '../lib/strapi';

const base  = import.meta.env.BASE_URL;
const rates = await getRates();

const tbillRates = rates.filter(r => r.instrument === 'T-Bill').sort((a,b) => a.tenor.localeCompare(b.tenor));
const tbondRates = rates.filter(r => r.instrument === 'T-Bond').sort((a,b) => a.tenor.localeCompare(b.tenor));
const repoRate   = rates.find(r => r.instrument === 'Repo');
---

<BaseLayout
  title="HNB Securities — CBSL Primary Dealer"
  description="CBSL-appointed Primary Dealer since 1992. Direct access to T-Bills, T-Bonds, and Repo instruments."
>

<div class="page-header"><div class="page-header-inner">
  <div class="page-header-eyebrow">HNB Securities · CBSL Primary Dealer</div>
  <h1 class="page-header-h1">Government securities at the institutional level.</h1>
  <p class="page-header-lead">As a CBSL-appointed Primary Dealer since 1992, HNB Securities provides direct access to T-Bills, T-Bonds, and Repo instruments — beside your treasury desk.</p>
</div></div>

<main class="page-body">

<!-- S1: Primary Dealer credentials -->
<section class="section-host" data-section-id="s1-credentials" data-section-label="Credentials">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Simple">
    <div class="cred-monument">
      <div class="cred-monument-inner">
        <div class="reveal">
          <div class="section-eyebrow" style="color:oklch(1 0 0/.45)">Primary Dealer</div>
          <h2 class="section-h2" style="color:#fff">At the centre of Sri Lanka's sovereign debt market.</h2>
          <p style="color:oklch(1 0 0/.65);font-size:15px;line-height:1.6;margin-top:12px">CBSL-appointed since inception, HNB Securities participates in every T-Bill and T-Bond primary auction, providing wholesale liquidity and secondary market access for institutional and retail investors.</p>
          <a href={`${base}hnb-securities/repo/`} class="btn-white" style="margin-top:var(--sp-m)">View Repo rates →</a>
        </div>
        <div class="cred-stats-row reveal">
          <div class="cred-stat"><div class="cred-stat-bar"></div><div class="cred-stat-val">1992</div><div class="cred-stat-lbl">Year appointed as Primary Dealer</div></div>
          <div class="cred-stat"><div class="cred-stat-bar"></div>
            <div class="cred-stat-val">
              {tbillRates.length > 0
                ? `${tbillRates[0].rate.toFixed(2)}%`
                : '7.25%'}
            </div>
            <div class="cred-stat-lbl">T-Bill 91d — latest auction</div>
          </div>
          <div class="cred-stat"><div class="cred-stat-bar"></div><div class="cred-stat-val">3</div><div class="cred-stat-lbl">Tenors — 91d · 182d · 364d</div></div>
          <div class="cred-stat"><div class="cred-stat-bar"></div><div class="cred-stat-val">CBSL</div><div class="cred-stat-lbl">Appointed by the Central Bank of Sri Lanka</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- S2: Products -->
<section class="section-host" data-section-id="s2-products" data-section-label="Products">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Simple">
    <div class="section-pad" style="background:var(--bg-2)"><div class="section-inner">
      <div class="section-header reveal"><div class="section-eyebrow">Products</div><h2 class="section-h2">Government securities, simplified.</h2></div>
      <div class="grid-4">
        <div class="product-card reveal">
          <div class="product-tag">Repo / Reverse Repo</div>
          <div class="product-name">Repo</div>
          <div class="product-rate">{repoRate ? `${repoRate.rate.toFixed(2)}%` : '7.50%'}</div>
          <div class="product-desc">Short-term secured borrowing using government securities as collateral. Flexible tenors from overnight.</div>
          <a href={`${base}hnb-securities/repo/`} class="btn-ghost" style="font-size:13px;padding:8px 16px">Learn more →</a>
        </div>
        <div class="product-card reveal">
          <div class="product-tag">Treasury Bills</div>
          <div class="product-name">T-Bills</div>
          <div class="product-rate">{tbillRates.length > 0 ? `${tbillRates[0].rate.toFixed(2)}%` : '7.25%'}</div>
          <div class="product-desc">Short-term government instruments in three tenors: 91-day, 182-day, and 364-day. Issued by auction every Wednesday.</div>
          <a href={`${base}hnb-securities/tbill/`} class="btn-ghost" style="font-size:13px;padding:8px 16px">Learn more →</a>
        </div>
        <div class="product-card reveal">
          <div class="product-tag">Treasury Bonds</div>
          <div class="product-name">T-Bonds</div>
          <div class="product-rate">{tbondRates.length > 0 ? `${tbondRates[0].rate.toFixed(2)}%` : 'CBSL set'}</div>
          <div class="product-desc">Medium to long-term government instruments (2–30 years). Fixed coupon. Ideal for duration-matched portfolios.</div>
          <a href={`${base}contact-us/`} class="btn-ghost" style="font-size:13px;padding:8px 16px">Enquire →</a>
        </div>
        <div class="product-card reveal">
          <div class="product-tag">Rate Calculator</div>
          <div class="product-name">Rate Calculator</div>
          <div class="product-rate">Interactive</div>
          <div class="product-desc">Calculate your Repo or T-Bill yield and maturity amount. Contact our desk for a live quote.</div>
          <a href={`${base}hnb-securities/repo/calculator/`} class="btn-primary" style="font-size:13px;padding:8px 16px">Open calculator →</a>
        </div>
      </div>
    </div></div>
  </div>
</section>

<!-- S3: Live rates -->
<section class="section-host" data-section-id="s3-rates" data-section-label="Rates">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Simple">
    <div class="section-pad"><div class="section-inner">
      <div class="section-header reveal"><div class="section-eyebrow">Current Rates</div><h2 class="section-h2">Today's government security yields.</h2></div>
      <table class="proto-table reveal">
        <thead><tr><th>Instrument</th><th>Tenor</th><th>Rate / Yield</th><th>Source</th><th>Updated</th></tr></thead>
        <tbody>
          {repoRate && (
            <tr><td><strong>Repo</strong></td><td>{repoRate.tenor}</td><td style="font-weight:700;color:var(--primary)">{repoRate.rate.toFixed(2)}%</td><td>CBSL</td><td>Latest</td></tr>
          )}
          {tbillRates.map(r => (
            <tr><td><strong>T-Bill</strong></td><td>{r.tenor}</td><td style="font-weight:700;color:var(--primary)">{r.rate.toFixed(2)}%</td><td>CBSL Auction</td><td>Latest</td></tr>
          ))}
          {tbondRates.map(r => (
            <tr><td><strong>T-Bond</strong></td><td>{r.tenor}</td><td style="font-weight:700;color:var(--primary)">{r.rate.toFixed(2)}%</td><td>CBSL Auction</td><td>Latest</td></tr>
          ))}
          {rates.length === 0 && (
            <>
              <tr><td><strong>Repo</strong></td><td>Overnight</td><td style="font-weight:700;color:var(--primary)">7.50%</td><td>CBSL</td><td>Today</td></tr>
              <tr><td><strong>T-Bill</strong></td><td>91 days</td><td style="font-weight:700;color:var(--primary)">7.25%</td><td>CBSL Auction</td><td>Latest</td></tr>
              <tr><td><strong>T-Bill</strong></td><td>182 days</td><td style="font-weight:700;color:var(--primary)">7.50%</td><td>CBSL Auction</td><td>Latest</td></tr>
              <tr><td><strong>T-Bill</strong></td><td>364 days</td><td style="font-weight:700;color:var(--primary)">7.75%</td><td>CBSL Auction</td><td>Latest</td></tr>
            </>
          )}
        </tbody>
      </table>
      <p style="font-size:12px;color:var(--ink-3);margin-top:12px">Rates are indicative only and subject to change. Contact our treasury desk for live quotes.</p>
      <div style="margin-top:var(--sp-m)" class="reveal"><a href={`${base}hnb-securities/repo/calculator/`} class="btn-primary">Open Calculator →</a></div>
    </div></div>
  </div>
</section>

<div class="cta-final"><div class="cta-final-inner">
  <h2 class="cta-final-h2 reveal">Access Sri Lanka's sovereign debt market.</h2>
  <p class="cta-final-sub reveal">Speak to our treasury desk about Repo, T-Bills, and T-Bonds — structured for your mandate.</p>
  <div class="cta-final-btns reveal">
    <a href={`${base}contact-us/`} class="btn-white">Contact Treasury Desk</a>
    <a href={`${base}hnb-securities/repo/calculator/`} class="btn-ghost-white">Open Calculator →</a>
  </div>
  <div class="cta-trust reveal"><span>CBSL Primary Dealer</span><span class="dot">·</span><span>Since 1992</span><span class="dot">·</span><span>SEC Licensed</span></div>
</div></div>

</main>

</BaseLayout>

<style>
.cred-monument { background: var(--primary); padding: var(--sp-xl) var(--sp-m); }
.cred-monument-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 3fr; gap: var(--sp-l); align-items: start; }
.cred-stats-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 2px; }
.cred-stat { background: oklch(1 0 0/.07); padding: var(--sp-m); display: flex; flex-direction: column; gap: 8px; }
.cred-stat:first-child { border-radius: var(--radius) 0 0 var(--radius); }
.cred-stat:last-child { border-radius: 0 var(--radius) var(--radius) 0; }
.cred-stat-bar { height: 3px; background: var(--accent); border-radius: 2px; margin-bottom: 4px; }
.cred-stat-val { font-size: clamp(30px,3.5vw,52px); font-weight: 800; color: #fff; line-height: 1; }
.cred-stat-lbl { font-size: 12px; color: oklch(1 0 0/.55); }
.product-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: var(--sp-m); display: flex; flex-direction: column; gap: 12px; transition: box-shadow .18s; }
.product-card:hover { box-shadow: 0 8px 24px oklch(0.42 0.14 242/.10); }
.product-tag { font-size: 10px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--primary); }
.product-name { font-size: 20px; font-weight: 800; color: var(--ink); }
.product-rate { font-size: 28px; font-weight: 800; color: var(--primary); }
.product-desc { font-size: 13px; color: var(--ink-2); line-height: 1.55; flex: 1; }

@media (max-width: 900px) {
  .cred-monument-inner { grid-template-columns: 1fr; }
  .cred-stats-row { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px) {
  .cred-stats-row { grid-template-columns: 1fr; }
}
</style>
