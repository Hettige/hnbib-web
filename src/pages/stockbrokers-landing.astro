---
import LandingLayout from '../layouts/LandingLayout.astro';
const base = import.meta.env.BASE_URL;
---

<LandingLayout
  title="Open a Trading Account — HNB Stockbrokers"
  description="Open your equity trading account with Sri Lanka's most trusted investment bank. Research-driven. Technologically advanced."
>

<style>
.lp-hero { background:var(--primary); color:#fff; padding:80px 24px 100px; text-align:center; position:relative; overflow:hidden; }
.lp-hero::before { content:""; position:absolute; inset:0; background:radial-gradient(ellipse 80% 60% at 60% 40%, oklch(0.55 0.18 242 / .4), transparent); }
.lp-logo { display:inline-block; font-size:1.1rem; font-weight:800; letter-spacing:.04em; color:#fff; margin-bottom:48px; position:relative; z-index:1; }
.lp-logo span { color:var(--accent); }
.lp-hero h1 { font-size:clamp(2rem,5vw,3.2rem); font-weight:800; line-height:1.15; margin:0 auto .75rem; max-width:720px; position:relative; z-index:1; }
.lp-hero p { font-size:1.1rem; color:oklch(1 0 0/.8); max-width:520px; margin:0 auto 2rem; position:relative; z-index:1; }
.lp-hero-cta { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; position:relative; z-index:1; }
.lp-proof { display:flex; gap:3rem; justify-content:center; flex-wrap:wrap; margin-top:3rem; position:relative; z-index:1; }
.lp-proof-item { text-align:center; }
.lp-proof-item strong { display:block; font-size:1.8rem; font-weight:800; color:#fff; }
.lp-proof-item span { font-size:.8rem; color:oklch(1 0 0/.65); text-transform:uppercase; letter-spacing:.06em; }
.lp-steps { padding:72px 24px; background:#fff; }
.lp-steps-inner { max-width:960px; margin:0 auto; text-align:center; }
.lp-steps h2 { font-size:1.9rem; margin:0 0 .75rem; }
.lp-steps-sub { font-size:1rem; opacity:.65; margin:0 0 3rem; }
.steps-row { display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; }
.step { text-align:center; padding:1.5rem 1rem; }
.step-num { width:48px; height:48px; border-radius:50%; background:var(--primary); color:#fff; display:inline-flex; align-items:center; justify-content:center; font-weight:800; font-size:1.1rem; margin:0 auto 1rem; }
.step h3 { font-size:1rem; font-weight:700; margin:0 0 .5rem; }
.step p { font-size:.85rem; opacity:.65; margin:0; line-height:1.6; }
.lp-form-section { padding:72px 24px; background:oklch(0.97 0.010 244); }
.lp-form-wrap { max-width:520px; margin:0 auto; background:#fff; border-radius:calc(var(--radius)*2); padding:2.5rem; box-shadow:0 8px 40px oklch(0 0 0/.08); }
.lp-form-wrap h2 { font-size:1.5rem; margin:0 0 .5rem; }
.lp-form-wrap p { font-size:.9rem; opacity:.65; margin:0 0 1.5rem; }
.lp-form { display:flex; flex-direction:column; gap:1rem; }
.lp-form label { font-size:.75rem; font-weight:700; letter-spacing:.06em; text-transform:uppercase; opacity:.55; margin-bottom:.25rem; display:block; }
.lp-form input, .lp-form select { width:100%; padding:.75rem 1rem; border:1px solid oklch(0.82 0.015 244); border-radius:var(--radius); font-family:inherit; font-size:.95rem; outline:none; transition:border-color .2s; }
.lp-form input:focus, .lp-form select:focus { border-color:var(--primary); }
.form-row-2 { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.lp-submit { background:var(--primary); color:#fff; border:none; padding:1rem; border-radius:var(--radius); font-family:inherit; font-weight:700; font-size:1rem; cursor:pointer; transition:opacity .2s; }
.lp-submit:hover { opacity:.85; }
.lp-form-note { font-size:.75rem; opacity:.5; text-align:center; margin-top:.75rem; }
.lp-benefits { padding:72px 24px; background:#fff; }
.lp-benefits-inner { max-width:960px; margin:0 auto; }
.lp-benefits h2 { font-size:1.9rem; text-align:center; margin:0 0 3rem; }
.benefits-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
.benefit-card { padding:1.75rem; border:1px solid oklch(0.88 0.015 244); border-radius:calc(var(--radius)*1.5); }
.benefit-icon { font-size:1.75rem; margin-bottom:1rem; }
.benefit-card h3 { font-size:1.05rem; font-weight:700; margin:0 0 .5rem; color:var(--primary); }
.benefit-card p { font-size:.88rem; opacity:.7; margin:0; line-height:1.65; }
.lp-footer { padding:32px 24px; background:var(--ink); color:oklch(1 0 0/.6); text-align:center; font-size:.8rem; }
.lp-footer a { color:oklch(1 0 0/.5); text-decoration:none; margin:0 .75rem; }
.lp-footer a:hover { color:#fff; }
@media(max-width:768px){
  .steps-row { grid-template-columns:repeat(2,1fr); }
  .benefits-grid { grid-template-columns:1fr; }
  .form-row-2 { grid-template-columns:1fr; }
  .lp-proof { gap:1.5rem; }
}
@media(max-width:480px){
  .steps-row { grid-template-columns:1fr; }
}
</style>

<!-- Hero -->
<section class="lp-hero">
  <div class="lp-logo">HNB<span>IB</span> &nbsp;Stockbrokers</div>
  <h1>Invest in the Colombo Stock Exchange with Confidence</h1>
  <p>Open your equity trading account with Sri Lanka's most trusted investment bank. Research-driven. Technologically advanced.</p>
  <div class="lp-hero-cta">
    <a class="btn-white" href="#open-account">Open an Account</a>
    <a class="btn-ghost-white" href={`${base}hnb-stockbrokers/`}>Learn More</a>
  </div>
  <div class="lp-proof">
    <div class="lp-proof-item"><strong>LKR 15Bn+</strong><span>Assets Under Custody</span></div>
    <div class="lp-proof-item"><strong>25+ Years</strong><span>Market Experience</span></div>
    <div class="lp-proof-item"><strong>Top 5</strong><span>CSE Broker by Volume</span></div>
    <div class="lp-proof-item"><strong>50,000+</strong><span>Active Investors</span></div>
  </div>
</section>

<!-- Steps -->
<section class="lp-steps">
  <div class="lp-steps-inner">
    <h2>How to Get Started</h2>
    <p class="lp-steps-sub">Open your account in four simple steps — fully digital, no branch visit required</p>
    <div class="steps-row">
      <div class="step">
        <div class="step-num">1</div>
        <h3>Fill the Form</h3>
        <p>Enter your basic details below. Takes under 3 minutes.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3>Upload KYC</h3>
        <p>Submit NIC/Passport copy and proof of address digitally.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3>E-Sign Agreement</h3>
        <p>Review and sign your client agreement electronically.</p>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <h3>Fund &amp; Trade</h3>
        <p>Deposit via online banking and start trading on the CSE.</p>
      </div>
    </div>
  </div>
</section>

<!-- Form -->
<section class="lp-form-section" id="open-account">
  <div class="lp-form-wrap">
    <h2>Open Your Account</h2>
    <p>A relationship manager will contact you within one business day.</p>
    <form class="lp-form">
      <div class="form-row-2">
        <div><label>First Name</label><input type="text" placeholder="Ashan"></div>
        <div><label>Last Name</label><input type="text" placeholder="Perera"></div>
      </div>
      <div><label>Email Address</label><input type="email" placeholder="ashan@example.com"></div>
      <div><label>Mobile Number</label><input type="tel" placeholder="+94 77 000 0000"></div>
      <div>
        <label>NIC / Passport</label>
        <input type="text" placeholder="199XXXXXXXX or Passport No.">
      </div>
      <div>
        <label>Investment Experience</label>
        <select>
          <option value="">Select…</option>
          <option>New to investing</option>
          <option>1–3 years</option>
          <option>3–10 years</option>
          <option>10+ years</option>
        </select>
      </div>
      <div>
        <label>Monthly Investment Budget</label>
        <select>
          <option value="">Select…</option>
          <option>Under LKR 50,000</option>
          <option>LKR 50,000 – 250,000</option>
          <option>LKR 250,000 – 1,000,000</option>
          <option>Over LKR 1,000,000</option>
        </select>
      </div>
      <button type="submit" class="lp-submit">Submit Application →</button>
      <p class="lp-form-note">Your information is encrypted and protected under our <a href={`${base}privacy-policy/`} style="color:var(--primary);">Privacy Policy</a>.</p>
    </form>
  </div>
</section>

<!-- Benefits -->
<section class="lp-benefits">
  <div class="lp-benefits-inner">
    <h2>Why HNB Stockbrokers?</h2>
    <div class="benefits-grid">
      <div class="benefit-card">
        <div class="benefit-icon">📊</div>
        <h3>Research-Backed Decisions</h3>
        <p>Access daily equity reports, sector analyses, and earnings previews prepared by our in-house research team.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon">💻</div>
        <h3>Digital Trading Platform</h3>
        <p>Trade on the CSE via web and mobile with real-time market data, portfolio analytics, and alerts.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon">🛡️</div>
        <h3>Regulated &amp; Secure</h3>
        <p>Licensed by the Securities &amp; Exchange Commission of Sri Lanka. Client assets held in segregated custody accounts.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon">👤</div>
        <h3>Dedicated Relationship Manager</h3>
        <p>Every client is assigned a personal relationship manager available via phone, email, and chat.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon">🏦</div>
        <h3>HNB Banking Integration</h3>
        <p>Seamlessly link your HNB bank account for instant fund transfers, settlement, and consolidated reporting.</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon">📈</div>
        <h3>IPO &amp; Rights Issue Access</h3>
        <p>Priority allocation and advisory support for upcoming IPOs, rights issues, and corporate actions on the CSE.</p>
      </div>
    </div>
  </div>
</section>

<div class="lp-footer">
  <p>© 2024 HNB Stockbrokers (Pvt) Ltd — A subsidiary of HNB Investment Bank Limited. Licensed by the SEC of Sri Lanka.</p>
  <p style="margin-top:.5rem;">
    <a href={`${base}hnb-stockbrokers/`}>Full Website</a>
    <a href={`${base}privacy-policy/`}>Privacy</a>
    <a href={`${base}terms-and-conditions/`}>Terms</a>
    <a href={`${base}contact-us/`}>Contact</a>
  </p>
</div>

</LandingLayout>
