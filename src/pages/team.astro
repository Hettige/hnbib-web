---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTeamMembers, imgUrl } from '../lib/strapi';

const base    = import.meta.env.BASE_URL;
const members = await getTeamMembers();

// Group by department
const departments = [...new Set(members.map(m => m.department))];
---

<BaseLayout
  title="Our Team — HNB Investment Bank"
  description="Meet the professionals behind Sri Lanka's premier full-service investment bank."
>

<div class="page-header"><div class="page-header-inner">
  <div class="page-header-eyebrow">Our People</div>
  <h1 class="page-header-h1">The team behind Sri Lanka's capital markets.</h1>
  <p class="page-header-lead">Experienced professionals across stockbroking, fixed income, corporate finance, and fund management — united by a commitment to client outcomes.</p>
</div></div>

<main class="page-body">

{departments.map(dept => {
  const group = members.filter(m => m.department === dept);
  return (
    <section class="section-pad" style={dept !== departments[0] ? 'padding-top:0' : ''}>
      <div class="section-inner">
        <h2 class="dept-title reveal">{dept}</h2>
        <div class="team-grid reveal-group">
          {group.map(m => (
            <div class="team-card">
              <div class="team-photo">
                {m.photo
                  ? <img src={imgUrl(m.photo, 'small')} alt={m.name} loading="lazy" />
                  : <div class="team-placeholder"><span>{m.name.split(' ').map(n => n[0]).join('').slice(0,2)}</span></div>
                }
              </div>
              <div class="team-info">
                <h3 class="team-name">{m.name}</h3>
                <p class="team-role">{m.role}</p>
                {m.bio && <p class="team-bio">{m.bio}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  );
})}

{members.length === 0 && (
  <section class="section-pad">
    <div class="section-inner">
      <p style="color:var(--ink-3);text-align:center;padding:var(--sp-xl) 0">Team information coming soon.</p>
    </div>
  </section>
)}

<div class="cta-final"><div class="cta-final-inner">
  <h2 class="cta-final-h2 reveal">Work with us.</h2>
  <p class="cta-final-sub reveal">HNB Investment Bank offers careers across capital markets, corporate finance, and support functions. We are always looking for exceptional talent.</p>
  <div class="cta-final-btns reveal">
    <a href="mailto:careers@hnbib.lk" class="btn-white">View Careers</a>
    <a href={`${base}about-us/`} class="btn-ghost-white">About HNBIB →</a>
  </div>
</div></div>

</main>

</BaseLayout>

<style>
.dept-title {
  font-size: clamp(1.2rem, 2vw, 1.6rem);
  font-weight: 700;
  color: var(--primary);
  margin: 0 0 var(--sp-l);
  padding-bottom: var(--sp-s);
  border-bottom: 2px solid var(--accent);
  display: inline-block;
}
.team-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--sp-l);
  margin-top: var(--sp-m);
}
.team-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: calc(var(--radius) * 1.5);
  padding: var(--sp-l) var(--sp-m);
  transition: box-shadow .2s, transform .2s;
}
.team-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px oklch(0.42 0.14 242/.10); }
.team-photo {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: var(--sp-m);
  border: 3px solid oklch(var(--primary-l) var(--primary-c) var(--primary-h) / .15);
  flex-shrink: 0;
}
.team-photo img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
.team-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--primary), oklch(0.55 0.14 260));
  display: flex;
  align-items: center;
  justify-content: center;
}
.team-placeholder span { color: #fff; font-size: 1.8rem; font-weight: 700; }
.team-info { flex: 1; }
.team-name { font-size: 1rem; font-weight: 600; color: var(--primary); margin: 0 0 4px; }
.team-role { font-size: 0.82rem; color: var(--ink-3); margin: 0 0 var(--sp-s); }
.team-bio  { font-size: 0.80rem; color: var(--ink-2); line-height: 1.6; margin: 0; }

@media (max-width: 1024px) { .team-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 768px)  { .team-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px)  { .team-grid { grid-template-columns: 1fr; } }
</style>
