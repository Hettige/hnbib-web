---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTeamMembers, imgUrl } from '../lib/strapi';

const base    = import.meta.env.BASE_URL;
const members = await getTeamMembers();

// Group by department
const groups: Record<string, typeof members> = {};
for (const m of members) {
  (groups[m.department] ??= []).push(m);
}
const deptOrder = ['Executive', 'Stockbrokers', 'Securities', 'Corporate Finance', 'Research', 'Operations'];
const sortedGroups = deptOrder.filter(d => groups[d]?.length);
---

<BaseLayout
  title="Our Team - HNB Investment Bank"
  description="Meet the leadership and specialists driving HNB Investment Bank's excellence across all business lines."
>
  <div id="site-header" class="site-header page-hero-simple">
    <div class="page-hero-inner section-inner">
      <p class="overline">Our People</p>
      <h1>Leadership &amp; Team</h1>
      <p class="hero-sub">Experienced professionals across capital markets, corporate finance, and fund management.</p>
    </div>
  </div>

  {sortedGroups.map(dept => (
    <section class="section-pad" id={dept.toLowerCase().replace(/\s+/g, '-')}>
      <div class="section-inner">
        <h2 class="dept-heading">{dept}</h2>
        <div class="team-grid">
          {groups[dept].map(m => (
            <div class="team-card">
              <div class="team-photo">
                {m.photo
                  ? <img src={imgUrl(m.photo, 'medium')} alt={m.photo.alternativeText ?? m.name} loading="lazy" />
                  : <div class="team-photo-placeholder">
                      <span>{m.name.split(' ').map(n => n[0]).join('').slice(0,2)}</span>
                    </div>
                }
              </div>
              <div class="team-info">
                <h3 class="team-name">{m.name}</h3>
                <p class="team-role">{m.role}</p>
                {m.linkedIn && (
                  <a href={m.linkedIn} target="_blank" rel="noopener noreferrer" class="team-linkedin" aria-label={`${m.name} on LinkedIn`}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                    LinkedIn
                  </a>
                )}
                {m.bio && <p class="team-bio">{m.bio}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="section-pad" style="background:var(--bg)">
    <div class="section-inner" style="text-align:center">
      <h2>Join Our Team</h2>
      <p style="color:var(--text-muted);max-width:500px;margin:var(--sp-m) auto var(--sp-xl)">
        We're always looking for exceptional talent across all our business lines.
      </p>
      <a href="mailto:careers@hnbib.lk" class="btn btn-primary">View Opportunities</a>
    </div>
  </section>
</BaseLayout>

<style>
.page-hero-simple {
  background: linear-gradient(135deg, oklch(0.22 0.10 242), oklch(0.34 0.14 260));
  padding: var(--sp-3xl) 0 var(--sp-2xl);
  color: #fff;
}
.page-hero-inner { max-width: 640px; }
.page-hero-simple .overline { color: oklch(1 0 0 / .60); }
.page-hero-simple h1 { color: #fff; margin: var(--sp-xs) 0 var(--sp-m); }
.page-hero-simple .hero-sub { color: oklch(1 0 0 / .75); }

.dept-heading {
  font-size: 1.2rem;
  font-weight: 600;
  color: var(--primary);
  margin: 0 0 var(--sp-xl);
  padding-bottom: var(--sp-s);
  border-bottom: 2px solid var(--accent);
  display: inline-block;
}
.team-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--sp-l);
}
.team-card {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid oklch(0 0 0 / .08);
  background: #fff;
  transition: box-shadow .2s, transform .2s;
}
.team-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px oklch(0 0 0 / .10); }
.team-photo { aspect-ratio: 4/3; overflow: hidden; }
.team-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform .35s; }
.team-card:hover .team-photo img { transform: scale(1.04); }
.team-photo-placeholder {
  width: 100%; height: 100%;
  background: linear-gradient(135deg, var(--primary), oklch(0.55 0.14 260));
  display: flex; align-items: center; justify-content: center;
}
.team-photo-placeholder span { color: #fff; font-size: 2rem; font-weight: 700; }
.team-info { padding: var(--sp-m); }
.team-name { font-size: 0.96rem; font-weight: 600; color: var(--primary); margin: 0 0 4px; }
.team-role { font-size: 0.82rem; color: var(--text-muted); margin: 0 0 var(--sp-s); }
.team-linkedin { display: inline-flex; align-items: center; gap: 4px; font-size: 0.78rem; color: var(--accent); text-decoration: none; font-weight: 500; }
.team-linkedin:hover { text-decoration: underline; }
.team-bio { font-size: 0.82rem; color: var(--text-muted); margin-top: var(--sp-s); line-height: 1.6; }

@media (max-width: 1024px) { .team-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 768px)  { .team-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px)  { .team-grid { grid-template-columns: 1fr; } }
</style>
