---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="About Us — HNB Investment Bank"
  description="Discover HNB Investment Bank — Sri Lanka's leading full-service investment bank. Learn about our leadership, values, 30-year track record, and capital markets expertise."
>

<div class="page-header"><div class="page-header-inner">
  <div class="page-header-eyebrow">About HNB Investment Bank</div>
  <h1 class="page-header-h1">Sri Lanka's full-service investment bank since 1992.</h1>
  <p class="page-header-lead">A subsidiary of Hatton National Bank PLC — Sri Lanka's second-largest listed bank. We operate across stockbroking, primary dealership, corporate finance, and fund management.</p>
</div></div>

<main>

<!-- S1: WHO WE ARE — Image + Text -->
<section class="section-host" data-section-id="s1-who" data-section-label="Who We Are">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Image Split">
    <div class="about-split">
      <div class="about-split-img reveal-left">
        <img src={`${base}assets/images/hero/hnbib-cc-1024x808.webp`} alt="HNB Investment Bank — Sri Lanka's capital markets leader" loading="lazy">
      </div>
      <div class="about-split-content">
        <div class="section-eyebrow reveal">Who We Are</div>
        <h2 class="section-h2 reveal">Acuity Partners heritage. HNB Group strength.</h2>
        <p class="section-lead reveal" style="max-width:100%">HNB Investment Bank is the capital markets arm of Hatton National Bank PLC. Evolved from the renowned Acuity Partners brand — a joint venture with Deutsche Bank — we have been at the heart of Sri Lanka's financial markets for over three decades.</p>
        <p style="font-size:14px;line-height:1.7;color:var(--ink-2);max-width:560px" class="reveal">We hold three critical market licences: CSE Full Member (stockbroking), CBSL Primary Dealer (government securities), and SEC Licensed Fund Manager. Together these allow us to serve the full breadth of Sri Lanka's capital market needs — from a retail investor's first trade to a landmark LKR 32 billion corporate transaction.</p>
        <div class="about-split-stats reveal-group">
          <div class="about-stat">
            <div class="about-stat-val" data-count-to="200" data-count-suffix="Bn+" data-count-prefix="LKR ">LKR 200Bn+</div>
            <div class="about-stat-lbl">Capital raised across equity &amp; debt</div>
          </div>
          <div class="about-stat">
            <div class="about-stat-val" data-count-to="33" data-count-suffix=" years">33 years</div>
            <div class="about-stat-lbl">Sri Lanka market leadership</div>
          </div>
          <div class="about-stat">
            <div class="about-stat-val" data-count-to="300" data-count-suffix="x">300x</div>
            <div class="about-stat-lbl">Record IPO oversubscription</div>
          </div>
          <div class="about-stat">
            <div class="about-stat-val" data-count-to="32" data-count-suffix="Bn" data-count-prefix="LKR ">LKR 32Bn</div>
            <div class="about-stat-lbl">Assets under management</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- S2: BOARD OF DIRECTORS -->
<section class="section-host" data-section-id="s2-board" data-section-label="Board">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Photo Cards">
    <div class="section-pad" style="background:var(--bg)"><div class="section-inner">
      <div class="section-header reveal">
        <div class="section-eyebrow">Leadership</div>
        <h2 class="section-h2">Board of Directors</h2>
        <p class="section-lead">Our board brings together capital markets expertise, banking leadership, and corporate governance experience from across Sri Lanka and the region.</p>
      </div>
      <div class="team-grid reveal-group" style="margin-top:var(--sp-l)">
        <div class="leader-card">
          <div class="leader-photo-wrap">
            <img src={`${base}assets/images/team/Ray-1024x819.webp`} alt="Ray Abeywardena" loading="lazy">
          </div>
          <div class="leader-body">
            <div class="leader-name">Ray Abeywardena</div>
            <div class="leader-title">Group Chief Executive Officer</div>
          </div>
        </div>
        <div class="leader-card">
          <div class="leader-photo-wrap">
            <img src={`${base}assets/images/team/Damith-1024x819.webp`} alt="Damith Pallewatte" loading="lazy">
          </div>
          <div class="leader-body">
            <div class="leader-name">Damith Pallewatte</div>
            <div class="leader-title">Director / Deputy CEO</div>
          </div>
        </div>
        <div class="leader-card">
          <div class="leader-photo-wrap">
            <img src={`${base}assets/images/team/Sanjay-1024x819.webp`} alt="Sanjay Wijemanne" loading="lazy">
          </div>
          <div class="leader-body">
            <div class="leader-name">Sanjay Wijemanne</div>
            <div class="leader-title">Director</div>
          </div>
        </div>
        <div class="leader-card" style="background:var(--bg-2);display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:290px;gap:12px;padding:var(--sp-m)">
          <div style="width:64px;height:64px;border-radius:50%;background:var(--line);display:flex;align-items:center;justify-content:center;color:var(--ink-3)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div style="text-align:center">
            <div class="leader-name">David Nigel Bartholomeusz</div>
            <div class="leader-title">Independent Non-Executive Director</div>
          </div>
        </div>
      </div>
    </div></div>
  </div>
</section>

<!-- S3: MANAGEMENT TEAM -->
<section class="section-host" data-section-id="s3-management" data-section-label="Management">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Photo Cards">
    <div class="section-pad" style="background:var(--bg-2)"><div class="section-inner">
      <div class="section-header reveal">
        <div class="section-eyebrow">Executive Team</div>
        <h2 class="section-h2">Management &amp; Operations</h2>
        <p class="section-lead">Deep specialists leading each business line — with collective experience spanning decades in Sri Lanka's capital markets, banking, and finance.</p>
      </div>
      <div class="team-grid reveal-group" style="margin-top:var(--sp-l)">
        <div class="leader-card">
          <div class="leader-photo-wrap">
            <img src={`${base}assets/images/team/Yaveen-1024x819.webp`} alt="Yaveen Amaratunga" loading="lazy">
          </div>
          <div class="leader-body">
            <div class="leader-name">Yaveen Amaratunga</div>
            <div class="leader-title">CEO — HNB Stockbrokers</div>
          </div>
        </div>
        <div class="leader-card">
          <div class="leader-photo-wrap">
            <img src={`${base}assets/images/team/Prashan-1024x819.webp`} alt="Prashan de Visser" loading="lazy">
          </div>
          <div class="leader-body">
            <div class="leader-name">Prashan de Visser</div>
            <div class="leader-title">CEO — HNB Securities</div>
          </div>
        </div>
        <div class="leader-card">
          <div class="leader-photo-wrap">
            <img src={`${base}assets/images/team/Shehan-1024x819.webp`} alt="Shehan Jayawardena" loading="lazy">
          </div>
          <div class="leader-body">
            <div class="leader-name">Shehan Jayawardena</div>
            <div class="leader-title">Head of Corporate Finance</div>
          </div>
        </div>
        <div class="leader-card">
          <div class="leader-photo-wrap">
            <img src={`${base}assets/images/team/Nayana-1024x819.webp`} alt="Nayana Karunaratne" loading="lazy">
          </div>
          <div class="leader-body">
            <div class="leader-name">Nayana Karunaratne</div>
            <div class="leader-title">Head of Research</div>
          </div>
        </div>
        <div class="leader-card">
          <div class="leader-photo-wrap">
            <img src={`${base}assets/images/team/Mayanthi-1024x819.webp`} alt="Mayanthi Perera" loading="lazy">
          </div>
          <div class="leader-body">
            <div class="leader-name">Mayanthi Perera</div>
            <div class="leader-title">Chief Financial Officer</div>
          </div>
        </div>
        <div class="leader-card">
          <div class="leader-photo-wrap">
            <img src={`${base}assets/images/team/Sanjeewa-W-1024x819.webp`} alt="Sanjeewa Weerasinghe" loading="lazy">
          </div>
          <div class="leader-body">
            <div class="leader-name">Sanjeewa Weerasinghe</div>
            <div class="leader-title">Head of Operations</div>
          </div>
        </div>
        <div class="leader-card">
          <div class="leader-photo-wrap">
            <img src={`${base}assets/images/team/Andrea-1024x819.webp`} alt="Andrea Fernando" loading="lazy">
          </div>
          <div class="leader-body">
            <div class="leader-name">Andrea Fernando</div>
            <div class="leader-title">Head of HR &amp; Administration</div>
          </div>
        </div>
        <div class="leader-card">
          <div class="leader-photo-wrap">
            <img src={`${base}assets/images/team/Shehan-Cooray-1024x819.webp`} alt="Shehan Cooray" loading="lazy">
          </div>
          <div class="leader-body">
            <div class="leader-name">Shehan Cooray</div>
            <div class="leader-title">Head of Legal &amp; Compliance</div>
          </div>
        </div>
      </div>
    </div></div>
  </div>
</section>

<!-- S4: CORE VALUES -->
<section class="section-host" data-section-id="s4-values" data-section-label="Values">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Icon Cards">
    <div class="section-pad" style="background:var(--bg)"><div class="section-inner">
      <div class="section-header reveal" style="text-align:center;max-width:560px;margin-left:auto;margin-right:auto">
        <div class="section-eyebrow">Our Core Values</div>
        <h2 class="section-h2">What drives us every day.</h2>
        <p class="section-lead" style="max-width:100%">Five principles that guide every client relationship, every transaction, and every decision we make in Sri Lanka's capital markets.</p>
      </div>
      <div class="values-grid reveal-group" style="margin-top:var(--sp-l)">
        <div class="value-card">
          <div class="value-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="value-name">Integrity</div>
          <div class="value-desc">Transparent, ethical conduct in every client interaction and market transaction — without exception.</div>
        </div>
        <div class="value-card">
          <div class="value-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <div class="value-name">Innovation</div>
          <div class="value-desc">Pioneering Sri Lanka's capital markets — from the nation's first GDR to its first green bond and first ETF.</div>
        </div>
        <div class="value-card">
          <div class="value-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div class="value-name">Collaboration</div>
          <div class="value-desc">Working alongside clients, regulators, and the HNB Group to unlock the best outcomes for Sri Lanka's economy.</div>
        </div>
        <div class="value-card">
          <div class="value-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
          </div>
          <div class="value-name">Stability</div>
          <div class="value-desc">Backed by Hatton National Bank Group, we bring institutional resilience and continuity to every mandate.</div>
        </div>
        <div class="value-card">
          <div class="value-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <div class="value-name">Excellence</div>
          <div class="value-desc">Committed to the highest standard in research, execution, and advice — consistently, across every business line.</div>
        </div>
      </div>
    </div></div>
  </div>
</section>

<!-- S5: AWARDS & RECOGNITION -->
<section class="section-host" data-section-id="s5-awards" data-section-label="Awards">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Award Cards">
    <div class="section-pad" style="background:var(--bg-2)"><div class="section-inner">
      <div class="section-header reveal">
        <div class="section-eyebrow">Awards &amp; Recognition</div>
        <h2 class="section-h2">Recognised for excellence.</h2>
        <p class="section-lead">Independent recognition of our standing in Sri Lanka's capital markets and investment banking community.</p>
      </div>
      <div class="awards-grid reveal-group" style="margin-top:var(--sp-l)">
        <div class="award-card">
          <div class="award-badge" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <div>
            <div class="award-year">LMD · 2023</div>
            <div class="award-name">Most Respected Entities in Sri Lanka — Sector Winner</div>
            <div class="award-body">Recognised by LMD magazine as the most respected entity in Sri Lanka's investment banking sector — a reflection of our three-decade track record and institutional integrity.</div>
          </div>
        </div>
        <div class="award-card">
          <div class="award-badge" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8.21 13.89L7 23l5-3 5 3-1.21-9.12"/><path d="M12 2L9.05 8.26 2 9.27l5 4.87-1.18 6.88L12 17.77l6.18 3.25L17 14.14l5-4.87-7.05-1.01L12 2z"/></svg>
          </div>
          <div>
            <div class="award-year">Brand Finance · 2023</div>
            <div class="award-name">Top Hundred Brands in Sri Lanka</div>
            <div class="award-body">Ranked among Sri Lanka's top 100 most valuable brands by Brand Finance — recognising the strength and recognition of the HNB Investment Bank name across the island's financial community.</div>
          </div>
        </div>
        <div class="award-card">
          <div class="award-badge" style="background:oklch(0.42 0.14 242 / 0.10);color:var(--primary)" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <div>
            <div class="award-year">CBSL · Since 2000</div>
            <div class="award-name">Appointed Primary Dealer — Central Bank of Sri Lanka</div>
            <div class="award-body">One of only a select number of institutions appointed as a Primary Dealer by the Central Bank of Sri Lanka — giving us direct auction access for T-Bills and T-Bonds since 2000.</div>
          </div>
        </div>
        <div class="award-card">
          <div class="award-badge" style="background:oklch(0.42 0.14 242 / 0.10);color:var(--primary)" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          </div>
          <div>
            <div class="award-year">CSE · Licensed Member</div>
            <div class="award-name">Colombo Stock Exchange — Full Trading Member</div>
            <div class="award-body">Authorised as a full member of the Colombo Stock Exchange, enabling direct market access, order execution, and settlement services for all CSE-listed securities on behalf of our clients.</div>
          </div>
        </div>
      </div>
    </div></div>
  </div>
</section>

<!-- S6: MILESTONES TIMELINE -->
<section class="section-host" data-section-id="s6-milestones" data-section-label="Milestones">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Timeline">
    <div class="section-pad" style="background:var(--bg)"><div class="section-inner">
      <div class="content-grid-split" style="align-items:start">
        <div>
          <div class="section-eyebrow reveal">Our History</div>
          <h2 class="section-h2 reveal">Three decades of capital market firsts.</h2>
          <p class="section-lead reveal">From Sri Lanka's first international equity offering to its first green bond, first ETF, and first high-yield bond — we have consistently pioneered what's possible in Sri Lanka's financial markets.</p>
          <div style="margin-top:var(--sp-l)" class="reveal">
            <div style="background:var(--primary);border-radius:var(--radius);padding:var(--sp-m);display:flex;flex-direction:column;gap:12px">
              <div style="font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:oklch(1 0 0/.50)">Landmark Transaction</div>
              <div style="font-size:20px;font-weight:700;color:#fff;line-height:1.3">Sri Lanka Telecom — LKR 32 Billion</div>
              <div style="font-size:13px;color:oklch(1 0 0/.65)">The largest single transaction on the Colombo Stock Exchange. A strategic stake sale that redefined the scale of what's possible in Sri Lanka's capital markets.</div>
            </div>
          </div>
        </div>
        <div class="milestones-track">
          <div class="milestone-item reveal">
            <div class="milestone-dot">92</div>
            <div>
              <div class="milestone-year">1992</div>
              <div class="milestone-text">Founded as capital markets arm of HNB Group</div>
              <div class="milestone-sub">Operating under the Acuity Partners joint venture with Deutsche Bank</div>
            </div>
          </div>
          <div class="milestone-item reveal">
            <div class="milestone-dot">00</div>
            <div>
              <div class="milestone-year">2000</div>
              <div class="milestone-text">Appointed CBSL Primary Dealer</div>
              <div class="milestone-sub">Central Bank of Sri Lanka confers Primary Dealer status for government securities</div>
            </div>
          </div>
          <div class="milestone-item reveal">
            <div class="milestone-dot">10</div>
            <div>
              <div class="milestone-year">2010s</div>
              <div class="milestone-text">Sri Lanka's first GDR — HNB Bank international equity offering</div>
              <div class="milestone-sub">The first Sri Lankan bank to issue Global Depositary Receipts on an international exchange</div>
            </div>
          </div>
          <div class="milestone-item reveal">
            <div class="milestone-dot">18</div>
            <div>
              <div class="milestone-year">2018</div>
              <div class="milestone-text">Sri Lanka's first Green Bond listed on the CSE</div>
              <div class="milestone-sub">Pioneered sustainable finance instruments in the domestic capital market</div>
            </div>
          </div>
          <div class="milestone-item reveal">
            <div class="milestone-dot">22</div>
            <div>
              <div class="milestone-year">2022</div>
              <div class="milestone-text">Sri Lanka's first high-yield bond — Fintrex Finance</div>
              <div class="milestone-sub">Opened a new asset class for fixed income investors in the post-restructuring era</div>
            </div>
          </div>
          <div class="milestone-item reveal">
            <div class="milestone-dot">23</div>
            <div>
              <div class="milestone-year">2023</div>
              <div class="milestone-text">LMD Most Respected Entity — Sector Winner</div>
              <div class="milestone-sub">Recognised as the most respected investment banking entity in Sri Lanka</div>
            </div>
          </div>
        </div>
      </div>
    </div></div>
  </div>
</section>

<!-- CTA -->
<div class="cta-a cta-a-mesh">
  <div class="cta-a-inner">
    <h2 class="cta-a-h2 reveal">Start your investment journey with us.</h2>
    <p class="cta-a-sub reveal">Open an account or speak to an advisor — backed by 30 years of Sri Lanka's capital market experience and the Hatton National Bank Group.</p>
    <div class="cta-a-btns reveal">
      <a href={`${base}hnb-stockbrokers/`} class="btn-white">Open a Trading Account →</a>
      <a href={`${base}contact-us/`} class="btn-ghost-white">Speak to an Advisor</a>
    </div>
    <div class="cta-trust-line reveal">
      <span>CSE Full Member</span><span class="trust-dot">·</span>
      <span>CBSL Primary Dealer</span><span class="trust-dot">·</span>
      <span>SEC Licensed</span><span class="trust-dot">·</span>
      <span>Est. 1992</span>
    </div>
  </div>
</div>

</main>

</BaseLayout>

<style>
/* Team cards */
.team-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; }
.leader-card { background:var(--card); border:1px solid var(--line); border-radius:var(--radius); overflow:hidden; transition:box-shadow var(--dur-mid) var(--ease-out), transform var(--dur-mid) var(--ease-out); }
.leader-card:hover { box-shadow:0 8px 28px oklch(0.42 0.14 242 / 0.12); transform:translateY(-3px); }
.leader-photo-wrap { height:220px; overflow:hidden; background:var(--bg-2); }
.leader-photo-wrap img { width:100%; height:100%; object-fit:cover; object-position:center top; transition:transform .6s var(--ease-out); }
.leader-card:hover .leader-photo-wrap img { transform:scale(1.04); }
.leader-body { padding:16px; }
.leader-name { font-size:15px; font-weight:700; color:var(--ink); }
.leader-title { font-size:12px; color:var(--ink-3); margin-top:3px; line-height:1.4; }

/* Core values */
.values-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:16px; }
.value-card { background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:28px 20px; text-align:center; display:flex; flex-direction:column; align-items:center; gap:14px; transition:box-shadow var(--dur-mid), transform var(--dur-mid), border-color var(--dur-mid); }
.value-card:hover { box-shadow:0 8px 24px oklch(0.42 0.14 242 / 0.10); transform:translateY(-3px); border-color:var(--primary); }
.value-icon { width:52px; height:52px; background:oklch(0.42 0.14 242 / 0.08); border-radius:12px; display:flex; align-items:center; justify-content:center; color:var(--primary); transition:background var(--dur-mid), color var(--dur-mid); }
.value-card:hover .value-icon { background:var(--primary); color:#fff; }
.value-name { font-size:15px; font-weight:700; color:var(--ink); }
.value-desc { font-size:12px; color:var(--ink-2); line-height:1.55; }

/* Awards */
.awards-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
.award-card { background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:var(--sp-m); display:flex; gap:20px; align-items:flex-start; transition:box-shadow var(--dur-mid), transform var(--dur-mid); }
