---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getRates, getArticles, getPartners, getSiteSettings, formatDate, imgUrl } from '../lib/strapi';

const base = import.meta.env.BASE_URL;

const [rates, articles, partners, settings] = await Promise.all([
  getRates(),
  getArticles({ limit: 5 }),
  getPartners(),
  getSiteSettings(),
]);

const featuredArticle = articles[0] ?? null;
const listArticles    = articles.slice(1, 5);

// Sort rates for display
const tbillRates = rates.filter(r => r.instrument === 'T-Bill').sort((a,b) => a.tenor.localeCompare(b.tenor));
const tbondRates = rates.filter(r => r.instrument === 'T-Bond').sort((a,b) => a.tenor.localeCompare(b.tenor));
const repoRate   = rates.find(r => r.instrument === 'Repo');
---

<BaseLayout title="HNB Investment Bank — Empowering Progress Across Sri Lanka's Capital Markets">

