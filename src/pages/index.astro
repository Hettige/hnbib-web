            </div>
          )) : (
            <>
              <div class="partner-logo"><img src={`${base}assets/images/partner-logos/Sri_Lanka_Telecom-Logo-scaled-e1750418321153-1024x488.png`} alt="Sri Lanka Telecom" loading="lazy" /></div>
              <div class="partner-logo"><img src={`${base}assets/images/partner-logos/Hayleys_logo.png`} alt="Hayleys PLC" loading="lazy" /></div>
              <div class="partner-logo"><img src={`${base}assets/images/partner-logos/hemas-logo-color-1024x525.png`} alt="Hemas Holdings" loading="lazy" /></div>
              <div class="partner-logo"><img src={`${base}assets/images/partner-logos/NDB-Logo-e1750397706677-768x194.jpg`} alt="National Development Bank" loading="lazy" /></div>
              <div class="partner-logo"><img src={`${base}assets/images/partner-logos/Lanka_Hospitals_logo.png`} alt="Lanka Hospitals" loading="lazy" /></div>
              <div class="partner-logo"><img src={`${base}assets/images/partner-logos/union-bank-logo-original-1024x193.jpg`} alt="Union Bank" loading="lazy" /></div>
              <div class="partner-logo"><img src={`${base}assets/images/partner-logos/Fintrex-Finance-2022-Logo.jpg`} alt="Fintrex Finance" loading="lazy" /></div>
              <div class="partner-logo"><img src={`${base}assets/images/partner-logos/JAT_LOGO-e1750408029550.png`} alt="JAT Holdings" loading="lazy" /></div>
              <div class="partner-logo"><img src={`${base}assets/images/partner-logos/HPL_Logo.png`} alt="HPL" loading="lazy" /></div>
              <div class="partner-logo"><img src={`${base}assets/images/partner-logos/AsianAlliancelogo-new3-1-e1750417612245.jpg`} alt="Asian Alliance Insurance" loading="lazy" /></div>
              <div class="partner-logo"><img src={`${base}assets/images/partner-logos/Teejay_Lanka_logo-e1750668191871.jpg`} alt="Teejay Lanka" loading="lazy" /></div>
