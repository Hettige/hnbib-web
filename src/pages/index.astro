<!-- ══════════════════════════════════════════════════════════
     S9 — LATEST NEWS · Featured Lead
══════════════════════════════════════════════════════════ -->
<section class="section-host" data-section-id="s9-news" data-section-label="News">
  <div class="variant section-toggle-active" data-variant="B" data-variant-label="Featured Lead">
    <div class="news-b">
      <div class="news-b-inner">
        <div class="section-header reveal" style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:16px">
          <div>
            <div class="section-eyebrow">Latest Insights</div>
            <h2 class="section-h2">Market intelligence &amp; company news.</h2>
          </div>
          <a href={`${base}news/`} class="btn-ghost" style="flex-shrink:0">View all insights →</a>
        </div>
        <div class="news-b-layout">
          {featuredArticle ? (
            <div class="news-featured reveal">
              <div class="news-featured-img" style={featuredArticle.featuredImage ? `background-image:url('${imgUrl(featuredArticle.featuredImage, 'medium')}');background-size:cover;background-position:center` : ''}>
                <div class="news-featured-img-overlay">
                  <div class="news-tag" style="color:oklch(0.85 0.14 141)">{featuredArticle.category}</div>
                  <div style="font-size:11px;color:oklch(1 0 0 / 0.55);margin-top:4px">{formatDate(featuredArticle.publishDate)} · {featuredArticle.readTime ?? '5 min read'}</div>
                </div>
              </div>
              <div class="news-featured-body">
                <div class="news-featured-pull">
                  <div class="news-featured-pull-bar"></div>
                  <div class="news-featured-pull-text">{featuredArticle.excerpt}</div>
                </div>
                <div class="news-featured-title">{featuredArticle.title}</div>
                <div class="news-featured-desc">{featuredArticle.excerpt}</div>
                <a href={`${base}news/${featuredArticle.slug}/`} class="btn-primary" style="align-self:flex-start;margin-top:8px">Read the full note →</a>
              </div>
            </div>
          ) : (
            <div class="news-featured reveal">
              <div class="news-featured-img">
                <div class="news-featured-img-overlay">
                  <div class="news-tag" style="color:oklch(0.85 0.14 141)">Market Commentary</div>
                  <div style="font-size:11px;color:oklch(1 0 0 / 0.55);margin-top:4px">15 May 2026 · 5 min read</div>
                </div>
              </div>
              <div class="news-featured-body">
                <div class="news-featured-pull">
                  <div class="news-featured-pull-bar"></div>
                  <div class="news-featured-pull-text">The ASPI has added 18% year-to-date. Institutional flows are returning to Sri Lanka's equity market.</div>
                </div>
                <div class="news-featured-title">ASPI crosses 22,000 — what the recovery means for equity investors in 2026</div>
                <div class="news-featured-desc">After a sustained period of macroeconomic pressure, Sri Lanka's equity market is signalling a clear inflection. Our Head of Research unpacks the drivers and where institutional money is positioning.</div>
                <a href={`${base}news/`} class="btn-primary" style="align-self:flex-start;margin-top:8px">Read the full note →</a>
              </div>
            </div>
          )}
          <div class="news-list reveal">
            {listArticles.length > 0 ? listArticles.map(a => (
              <div class="news-list-item">
                <div style="display:flex;justify-content:space-between;align-items:center;gap:8px">
                  <div class="news-tag">{a.category}</div>
                  <div style="font-size:10px;color:var(--ink-3)">{a.readTime ?? '3 min read'}</div>
                </div>
                <div class="news-list-title"><a href={`${base}news/${a.slug}/`}>{a.title}</a></div>
                <div class="news-list-meta">{formatDate(a.publishDate)}</div>
              </div>
            )) : (
              <>
                <div class="news-list-item">
                  <div style="display:flex;justify-content:space-between;align-items:center;gap:8px">
                    <div class="news-tag">Fixed Income</div>
                    <div style="font-size:10px;color:var(--ink-3)">3 min read</div>
                  </div>
                  <div class="news-list-title"><a href={`${base}news/`}>T-Bill yields ease for the third consecutive auction</a></div>
                  <div class="news-list-meta">12 May 2026</div>
                </div>
                <div class="news-list-item">
                  <div style="display:flex;justify-content:space-between;align-items:center;gap:8px">
                    <div class="news-tag">Corporate Finance</div>
                    <div style="font-size:10px;color:var(--ink-3)">4 min read</div>
                  </div>
                  <div class="news-list-title"><a href={`${base}news/`}>HNB Investment Bank completes LKR 7.5 Bn debenture for HNB PLC</a></div>
                  <div class="news-list-meta">8 May 2026</div>
                </div>
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

