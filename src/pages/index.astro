<!-- ══════════════════════════════════════════════════════════
     S8 — PARTNER LOGOS · Trusted By
══════════════════════════════════════════════════════════ -->
<section class="section-host" data-section-id="s8-partners" data-section-label="Partners">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Logo Grid">
    <div class="partners-strip">
      <div class="partners-inner">
        <div class="partners-label reveal">Trusted by Sri Lanka's leading businesses</div>
        <div class="partners-grid reveal-group">
          {partners.length > 0 ? partners.map(p => (
            <div class="partner-logo">
              {p.logo
                ? <img src={imgUrl(p.logo, 'thumbnail')} alt={p.name} loading="lazy" />
