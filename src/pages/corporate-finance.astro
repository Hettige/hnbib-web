---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDeals } from '../lib/strapi';

const base    = import.meta.env.BASE_URL;
const deals    = await getDeals();
const featured  = deals.filter(d => d.isFeatured).slice(0, 3);
const allDeals  = deals.length > 0 ? deals : [];
---

<BaseLayout
  title="Corporate Finance — HNB Investment Bank"
  description="LKR 200 billion raised. IPOs, M&amp;A, debentures and structured finance for Sri Lanka's leading corporates."
>

<div class="page-header" style="background:var(--primary)"><div class="page-header-inner">
  <div class="page-header-eyebrow" style="color:oklch(1 0 0/.50)">Corporate Finance</div>
  <h1 class="page-header-h1" style="color:#fff">LKR 200 billion raised. Deal by deal.</h1>
  <p class="page-header-lead" style="color:oklch(1 0 0/.70)">From Sri Lanka's landmark IPOs to billion-rupee debentures — HNB Investment Bank is the corporate finance partner behind the country's most significant capital market transactions.</p>
</div></div>

<main class="page-body">

<!-- S1: Services -->
<section class="section-host" data-section-id="s1-services" data-section-label="Services">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Simple">
    <div class="section-pad"><div class="section-inner">
      <div class="section-header reveal"><div class="section-eyebrow">What We Do</div><h2 class="section-h2">Full origination-to-close capability.</h2></div>
      <div class="grid-3">
        <div class="card card-p reveal"><div style="font-size:28px;font-weight:800;color:var(--primary);margin-bottom:12px">01</div><div style="font-weight:700;font-size:16px;color:var(--ink);margin-bottom:8px">Equity Capital Markets</div><div style="font-size:13px;color:var(--ink-2);line-height:1.55">IPO origination and management, rights issues, private placements, and CSE listing advisory.</div></div>
        <div class="card card-p reveal"><div style="font-size:28px;font-weight:800;color:var(--primary);margin-bottom:12px">02</div><div style="font-weight:700;font-size:16px;color:var(--ink);margin-bottom:8px">Debt Capital Markets</div><div style="font-size:13px;color:var(--ink-2);line-height:1.55">Debenture issuance, subordinated debt, trust certificates, and structured debt placement.</div></div>
        <div class="card card-p reveal"><div style="font-size:28px;font-weight:800;color:var(--primary);margin-bottom:12px">03</div><div style="font-weight:700;font-size:16px;color:var(--ink);margin-bottom:8px">M&amp;A Advisory</div><div style="font-size:13px;color:var(--ink-2);line-height:1.55">Buy-side and sell-side advisory, controlling-interest transactions, cross-border deal structuring.</div></div>
      </div>
    </div></div>
  </div>
</section>

<!-- S2: Deal track record -->
<section class="section-host" data-section-id="s2-track-record" data-section-label="Track Record">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Simple">
    <div class="section-pad" style="background:var(--bg-2)"><div class="section-inner">
      <div class="section-header reveal"><div class="section-eyebrow">Track Record</div><h2 class="section-h2">Selected transactions.</h2></div>
      <table class="proto-table reveal">
        <thead><tr><th>Transaction</th><th>Type</th><th>Size</th><th>Year</th><th>Role</th></tr></thead>
        <tbody>
          {allDeals.length > 0 ? allDeals.map(d => (
            <tr>
              <td>{d.client}</td>
              <td><span class="deal-type">{d.dealType}</span></td>
              <td class="deal-size">{d.amountLabel}</td>
              <td>{d.year}</td>
              <td>{d.role}</td>
            </tr>
          )) : (
            <>
              <tr><td>Hayleys PLC</td><td><span class="deal-type">Debenture</span></td><td class="deal-size">Rs 7 Billion</td><td>2018</td><td>Joint Placement Agent</td></tr>
              <tr><td>NTT Data (Sri Lanka)</td><td><span class="deal-type">M&amp;A</span></td><td class="deal-size">LKR 32 Billion</td><td>2017</td><td>Sell-side Advisor</td></tr>
              <tr><td>Singer Finance Lanka</td><td><span class="deal-type">Subordinated Debt</span></td><td class="deal-size">LKR 2 Billion</td><td>2022</td><td>Lead Manager</td></tr>
              <tr><td>Alpha Fire Services</td><td><span class="deal-type">IPO + M&amp;A</span></td><td class="deal-size">Controlling interest</td><td>2021</td><td>Manager &amp; Advisor</td></tr>
              <tr><td>Fintrex Finance</td><td><span class="deal-type">High-Yield Bond</span></td><td class="deal-size">LKR 500M (first ever)</td><td>2022</td><td>Lead Manager</td></tr>
              <tr><td>Union Bank</td><td><span class="deal-type">IPO</span></td><td class="deal-size">300× oversubscribed</td><td>2011</td><td>Manager</td></tr>
              <tr><td>Share swap (unnamed)</td><td><span class="deal-type">Structured</span></td><td class="deal-size">LKR 5,600 Million</td><td>2019</td><td>Advisor</td></tr>
              <tr><td>Interest rate swap</td><td><span class="deal-type">Derivative</span></td><td class="deal-size">USD 36.5 Million</td><td>2020</td><td>Arranger</td></tr>
            </>
          )}
        </tbody>
      </table>
    </div></div>
  </div>
</section>

<!-- S3: Featured case studies -->
{featured.length > 0 && (
  <section class="section-host" data-section-id="s3-cases" data-section-label="Case Studies">
    <div class="variant section-toggle-active" data-variant="A" data-variant-label="Simple">
      <div class="section-pad"><div class="section-inner">
        <div class="section-header reveal"><div class="section-eyebrow">Case Studies</div><h2 class="section-h2">Landmark transactions.</h2></div>
        <div class="grid-3">
          {featured.slice(0, 3).map(d => (
            <div class="case-card reveal">
              <div class="case-card-tag">{d.dealType} · {d.year}</div>
              <div class="case-card-headline">{d.client}</div>
              <div class="case-card-size">{d.amountLabel}</div>
              <div class="case-card-desc">{d.description ?? ''}</div>
            </div>
          ))}
        </div>
      </div></div>
    </div>
  </section>
)}

<!-- S4: Process -->
<section class="section-host" data-section-id="s4-process" data-section-label="Process">
  <div class="variant section-toggle-active" data-variant="C" data-variant-label="Ambitious">
    <div class="section-pad"><div class="section-inner">
      <div class="section-header reveal"><div class="section-eyebrow">How We Work</div><h2 class="section-h2">Seamless from start to close.</h2></div>
      <div style="display:flex;flex-direction:column">
        <div style="display:grid;grid-template-columns:80px 1fr;gap:var(--sp-m);align-items:center;padding:var(--sp-m) 0;border-bottom:1px solid var(--line)" class="reveal"><div style="font-size:56px;font-weight:800;color:var(--line-2);line-height:1">01</div><div><div style="font-size:18px;font-weight:700;color:var(--ink)">Mandate &amp; Structuring</div><div style="font-size:14px;color:var(--ink-2);margin-top:6px">We work with you to understand capital requirements, select the right instrument, and structure for your investor base.</div></div></div>
        <div style="display:grid;grid-template-columns:80px 1fr;gap:var(--sp-m);align-items:center;padding:var(--sp-m) 0;border-bottom:1px solid var(--line)" class="reveal"><div style="font-size:56px;font-weight:800;color:var(--line-2);line-height:1">02</div><div><div style="font-size:18px;font-weight:700;color:var(--ink)">Due Diligence &amp; Documentation</div><div style="font-size:14px;color:var(--ink-2);margin-top:6px">Legal, financial, and regulatory preparation — prospectus, information memorandum, and SEC submissions.</div></div></div>
        <div style="display:grid;grid-template-columns:80px 1fr;gap:var(--sp-m);align-items:center;padding:var(--sp-m) 0;border-bottom:1px solid var(--line)" class="reveal"><div style="font-size:56px;font-weight:800;color:var(--line-2);line-height:1">03</div><div><div style="font-size:18px;font-weight:700;color:var(--ink)">Marketing &amp; Book-Building</div><div style="font-size:14px;color:var(--ink-2);margin-top:6px">Investor roadshow and book-build targeting institutional, HNW, and retail demand. Allocation optimised for your shareholder register goals.</div></div></div>
        <div style="display:grid;grid-template-columns:80px 1fr;gap:var(--sp-m);align-items:center;padding:var(--sp-m) 0" class="reveal"><div style="font-size:56px;font-weight:800;color:var(--accent-d);line-height:1">04</div><div><div style="font-size:18px;font-weight:700;color:var(--ink)">Close &amp; Post-Deal Support</div><div style="font-size:14px;color:var(--ink-2);margin-top:6px">Settlement, CSE listing, regulatory filings, and ongoing IR support as required.</div></div></div>
      </div>
    </div></div>
  </div>
</section>

<div class="cta-final"><div class="cta-final-inner">
  <h2 class="cta-final-h2 reveal">Ready to raise capital or execute a transaction?</h2>
  <p class="cta-final-sub reveal">Contact our Corporate Finance team to discuss your mandate.</p>
  <div class="cta-final-btns reveal">
    <a href={`${base}contact-us/`} class="btn-white">Mandate Enquiry</a>
    <a href={`${base}news/`} class="btn-ghost-white">Our Deal News →</a>
  </div>
  <div class="cta-trust reveal"><span>LKR 200 Bn raised</span><span class="dot">·</span><span>CSE Member</span><span class="dot">·</span><span>SEC Licensed</span><span class="dot">·</span><span>Since 1992</span></div>
</div></div>

</main>

</BaseLayout>

<style>
.case-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: var(--sp-m); display: flex; flex-direction: column; gap: 12px; }
.case-card-tag { font-size: 10px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--primary); }
.case-card-headline { font-size: 18px; font-weight: 800; color: var(--ink); line-height: 1.2; }
.case-card-size { font-size: 28px; font-weight: 800; color: var(--primary); }
.case-card-desc { font-size: 13px; color: var(--ink-2); line-height: 1.55; flex: 1; }
.deal-type { font-size: 10px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; background: var(--bg-2); color: var(--ink-2); padding: 3px 8px; border-radius: 3px; display: inline-block; }
.deal-size { font-weight: 700; color: var(--primary); }
.step-card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: var(--sp-m); position: relative; }
.step-num { font-size: 48px; font-weight: 800; color: var(--line-2); line-height: 1; margin-bottom: 12px; }
.step-title { font-size: 16px; font-weight: 700; color: var(--ink); margin-bottom: 6px; }
.step-desc { font-size: 13px; color: var(--ink-2); line-height: 1.5; }
</style>
