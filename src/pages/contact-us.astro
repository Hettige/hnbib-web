---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contact Us — HNB Investment Bank"
  description="Reach our team across investment banking, securities, stockbroking, and wealth services."
>

<div class="page-header"><div class="page-header-inner">
  <div class="page-header-eyebrow">Contact Us</div>
  <h1 class="page-header-h1">Contact Us</h1>
  <p class="page-header-lead">Reach our team across investment banking, securities, and wealth services.</p>
</div></div>

<main class="page-body">

<!-- S1: Contact Form + Office Info -->
<section class="section-host" data-section-id="s1-contact" data-section-label="Contact">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Form+Info Split">
    <div class="section-pad"><div class="section-inner">
      <div class="contact-grid reveal">
        <div>
          <h2 style="margin-bottom:1.5rem;">Send Us a Message</h2>
          <form class="contact-form" id="contact-form"
                action="https://api.web3forms.com/submit" method="POST"
                novalidate>

            <!-- Web3Forms config -->
            <input type="hidden" name="access_key"  value="1daa864c-c030-4cb5-84f4-786a28313120">
            <input type="hidden" name="subject"      value="New Enquiry — HNB Investment Bank Website">
            <input type="hidden" name="from_name"    value="HNBIB Contact Form">
            <!-- Honeypot — catches bots, invisible to real users -->
            <input type="checkbox" name="botcheck" tabindex="-1"
                   aria-hidden="true" style="display:none;position:absolute;left:-9999px">

            <div class="form-row">
              <div class="form-field">
                <label for="cf-first">First Name *</label>
                <input type="text" id="cf-first" name="first_name"
                       placeholder="Ashan" required minlength="2" maxlength="60"
                       autocomplete="given-name">
                <span class="field-error" id="err-first"></span>
              </div>
              <div class="form-field">
                <label for="cf-last">Last Name *</label>
                <input type="text" id="cf-last" name="last_name"
                       placeholder="Perera" required minlength="2" maxlength="60"
                       autocomplete="family-name">
                <span class="field-error" id="err-last"></span>
              </div>
            </div>

            <div class="form-field">
              <label for="cf-email">Email Address *</label>
              <input type="email" id="cf-email" name="email"
                     placeholder="ashan@example.com" required maxlength="120"
                     autocomplete="email">
              <span class="field-error" id="err-email"></span>
            </div>

            <div class="form-field">
              <label for="cf-phone">Phone Number *</label>
              <input type="tel" id="cf-phone" name="phone"
                     placeholder="07XXXXXXXX or +94XXXXXXXXX" required maxlength="15"
                     autocomplete="tel">
              <span class="field-error" id="err-phone"></span>
            </div>

            <div class="form-field">
              <label for="cf-service">Service Interest *</label>
              <select id="cf-service" name="service" required>
                <option value="">Select a service…</option>
                <option>Equity Brokerage</option>
                <option>Fixed Income / Securities</option>
                <option>Corporate Finance &amp; Advisory</option>
                <option>Venture Capital (Lanka Ventures)</option>
                <option>Investor Relations</option>
                <option>Other</option>
              </select>
              <span class="field-error" id="err-service"></span>
            </div>

            <div class="form-field">
              <label for="cf-message">Message *</label>
              <textarea id="cf-message" name="message"
                        placeholder="Tell us how we can help…"
                        required minlength="10"></textarea>
              <div class="msg-meta">
                <span class="field-error" id="err-message"></span>
                <span class="word-count" id="msg-word-count">0 / 200 words</span>
              </div>
            </div>

            <!-- Feedback banners -->
            <div class="form-success" id="form-success" role="alert" aria-live="polite" hidden>
              <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Thank you! Your message has been received. We'll be in touch within 1 business day.
            </div>
            <div class="form-error-banner" id="form-error-banner" role="alert" aria-live="polite" hidden>
              Something went wrong — <span id="form-error-detail">please try again.</span>
              Email us at <a href="mailto:himansa.hettige@gmail.com">himansa.hettige@gmail.com</a>.
            </div>

            <button type="submit" class="btn-primary" id="cf-submit"
                    style="align-self:flex-start;">Send Message</button>
          </form>
        </div>
        <div class="contact-info-block" style="padding-top:1rem;">
          <div class="info-item">
            <div class="info-icon">📍</div>
            <div class="info-text">
              <h4>Head Office</h4>
              <p>No. 53 Dharmapala Mawatha<br>Colombo 03, Sri Lanka</p>
            </div>
          </div>
          <div class="info-item">
            <div class="info-icon">📞</div>
            <div class="info-text">
              <h4>Main Switchboard</h4>
              <a href="tel:+94112206206">+94 112 206 206</a>
            </div>
          </div>
          <div class="info-item">
            <div class="info-icon">✉️</div>
            <div class="info-text">
              <h4>General Inquiries</h4>
              <a href="mailto:himansa.hettige@gmail.com">himansa.hettige@gmail.com</a>
            </div>
          </div>
          <div class="info-item">
            <div class="info-icon">🕐</div>
            <div class="info-text">
              <h4>Business Hours</h4>
              <p>Monday – Friday: 8:30 AM – 5:00 PM<br>Saturday: 9:00 AM – 1:00 PM</p>
            </div>
          </div>
          <div class="map-embed">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3960.8140983176727!2d79.8530842!3d6.912818049999999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3ae25969e9f455ed%3A0xcf1a369fdc92547c!2sAcuity%20House%2C%2053%20Srimath%20Anagarika%20Dharmapala%20Mawatha%2C%20Colombo%2000300!5e0!3m2!1sen!2slk!4v1779962755695!5m2!1sen!2slk"
              width="100%" height="260" style="border:0;" allowfullscreen
              loading="lazy" referrerpolicy="no-referrer-when-downgrade"
              title="HNB Investment Bank location — Colombo 03"></iframe>
          </div>
        </div>
      </div>
    </div></div>
  </div>
</section>

<!-- S2: Department Contacts -->
<section class="section-host" data-section-id="s2-depts" data-section-label="Departments">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Dept Cards">
    <div class="section-pad" style="background:oklch(0.97 0.010 244)"><div class="section-inner">
      <h2 class="reveal" style="margin-bottom:2rem;">Specialist Desks</h2>
      <div class="dept-grid reveal">
        <div class="dept-card">
          <h4>Equity &amp; Brokerage</h4>
          <p>HNB Stockbrokers (Pvt) Ltd</p>
          <p><a href="tel:+94112206210">+94 112 206 210</a></p>
          <p><a href="mailto:stockbrokers@hnbib.lk">stockbrokers@hnbib.lk</a></p>
        </div>
        <div class="dept-card">
          <h4>Fixed Income</h4>
          <p>HNB Securities Ltd</p>
          <p><a href="tel:+94112206220">+94 112 206 220</a></p>
          <p><a href="mailto:securities@hnbib.lk">securities@hnbib.lk</a></p>
        </div>
        <div class="dept-card">
          <h4>Corporate Finance</h4>
          <p>Advisory &amp; Debt Capital</p>
          <p><a href="tel:+94112206230">+94 112 206 230</a></p>
          <p><a href="mailto:advisory@hnbib.lk">advisory@hnbib.lk</a></p>
        </div>
        <div class="dept-card">
          <h4>Lanka Ventures</h4>
          <p>Venture Capital &amp; PE</p>
          <p><a href="tel:+94112206240">+94 112 206 240</a></p>
          <p><a href="mailto:ventures@hnbib.lk">ventures@hnbib.lk</a></p>
        </div>
        <div class="dept-card">
          <h4>Investor Relations</h4>
          <p>Media &amp; Shareholder Desk</p>
          <p><a href="tel:+94112206250">+94 112 206 250</a></p>
          <p><a href="mailto:ir@hnbib.lk">ir@hnbib.lk</a></p>
        </div>
        <div class="dept-card">
          <h4>Compliance &amp; Legal</h4>
          <p>Regulatory Affairs</p>
          <p><a href="tel:+94112206260">+94 112 206 260</a></p>
          <p><a href="mailto:compliance@hnbib.lk">compliance@hnbib.lk</a></p>
        </div>
      </div>
    </div></div>
  </div>
</section>

<div class="cta-final"><div class="cta-final-inner">
  <h2 class="cta-final-h2 reveal">Visit Us in Colombo</h2>
  <p class="cta-final-sub reveal">Our team is available Monday to Friday. Walk in or schedule an appointment for dedicated service.</p>
  <div class="cta-final-btns reveal">
    <a class="btn-white" href="tel:+94112206206">Call +94 112 206 206</a>
    <a class="btn-ghost-white" href={`${base}careers/`}>Join Our Team →</a>
  </div>
</div></div>

</main>

</BaseLayout>

<script is:inline>
(function () {
  var form    = document.getElementById('contact-form');
  var btn     = document.getElementById('cf-submit');
  var success = document.getElementById('form-success');
  var errBan  = document.getElementById('form-error-banner');
  if (!form) return;

  // ── Button state machine ──────────────────────────────────────
  function setBtnState(state) {
    btn.classList.remove('btn-state-sending', 'btn-state-success', 'btn-state-error');
    if (state === 'sending') {
      btn.disabled = true;
      btn.textContent = 'Sending…';
      btn.classList.add('btn-state-sending');
    } else if (state === 'success') {
      btn.disabled = true;
      btn.textContent = '✓ Submitted';
      btn.classList.add('btn-state-success');
    } else if (state === 'error') {
      btn.disabled = false;
      btn.textContent = 'Not submitted — try again';
      btn.classList.add('btn-state-error');
    } else {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  }

  // ── Word counter ──────────────────────────────────────────────
  var msgArea  = document.getElementById('cf-message');
  var wordDisp = document.getElementById('msg-word-count');
  function countWords(str) {
    return str.trim() === '' ? 0 : str.trim().split(/\s+/).length;
  }
  function updateWordCount() {
    var n = countWords(msgArea.value);
    wordDisp.textContent = n + ' / 200 words';
    wordDisp.classList.toggle('over-limit', n > 200);
  }
  if (msgArea) msgArea.addEventListener('input', updateWordCount);

  // ── Custom field validators ───────────────────────────────────
  var NAME_RE  = /^[A-Za-z\s'\-]+$/;
  var PHONE_RE = /^(\+94[0-9]{9}|0[0-9]{9})$/;
  var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  var rules = {
    'cf-first': {
      err: 'err-first',
      check: function (el) {
        var v = el.value.trim();
        if (!v)               return 'First name is required.';
        if (!NAME_RE.test(v)) return 'First name must contain letters only.';
        if (v.length < 2)     return 'First name must be at least 2 characters.';
        return '';
      }
    },
    'cf-last': {
      err: 'err-last',
      check: function (el) {
        var v = el.value.trim();
        if (!v)               return 'Last name is required.';
        if (!NAME_RE.test(v)) return 'Last name must contain letters only.';
        if (v.length < 2)     return 'Last name must be at least 2 characters.';
        return '';
      }
    },
    'cf-email': {
      err: 'err-email',
      check: function (el) {
        var v = el.value.trim();
        if (!v)                return 'Email address is required.';
        if (!EMAIL_RE.test(v)) return 'Enter a valid email address (e.g. name@example.com).';
        return '';
      }
    },
    'cf-phone': {
      err: 'err-phone',
      check: function (el) {
        var v = el.value.trim().replace(/\s+/g, '');
        if (!v)                 return 'Phone number is required.';
        if (/[a-zA-Z]/.test(v)) return 'Phone number must contain digits only.';
        if (!PHONE_RE.test(v))  return 'Enter a valid Sri Lanka number: 07XXXXXXXX or +94XXXXXXXXX.';
        return '';
      }
    },
    'cf-service': {
      err: 'err-service',
      check: function (el) {
        if (!el.value) return 'Please select a service.';
        return '';
      }
    },
    'cf-message': {
      err: 'err-message',
      check: function (el) {
        var v = el.value.trim();
        if (!v)           return 'Message is required.';
        if (v.length < 10) return 'Message must be at least 10 characters.';
        if (countWords(v) > 200) return 'Message must not exceed 200 words.';
        return '';
      }
    }
  };

  function validate() {
    var ok = true;
    Object.keys(rules).forEach(function (id) {
      var input = document.getElementById(id);
      var errEl = document.getElementById(rules[id].err);
      var msg   = input ? rules[id].check(input) : 'Required.';
      if (errEl) errEl.textContent = msg;
      if (input) input.classList.toggle('input-invalid', !!msg);
      if (msg) ok = false;
    });
    return ok;
  }

  // Live validation on blur
  Object.keys(rules).forEach(function (id) {
    var input = document.getElementById(id);
    if (input) input.addEventListener('blur', function () {
      var errEl = document.getElementById(rules[id].err);
      var msg   = rules[id].check(input);
      if (errEl) errEl.textContent = msg;
      input.classList.toggle('input-invalid', !!msg);
    });
  });

  // ── AJAX submit ───────────────────────────────────────────────
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    success.hidden = true;
    errBan.hidden  = true;

    if (!validate()) return;

    setBtnState('sending');

    var fd = new FormData(form);
    var payload = {};
    fd.forEach(function (val, key) { payload[key] = val; });

    fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(payload),
    })
      .then(function (r) { return r.json(); })
      .then(function (json) {
        if (json.success) {
          setBtnState('success');
          form.reset();
          updateWordCount();
          success.hidden = false;
          success.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          var detail = document.getElementById('form-error-detail');
          if (detail) detail.textContent = json.message || 'please try again.';
          throw new Error(json.message || 'failed');
        }
      })
      .catch(function (err) {
        setBtnState('error');
        var detail = document.getElementById('form-error-detail');
        if (detail && err && err.message && err.message !== 'failed') {
          detail.textContent = err.message;
        }
        errBan.hidden = false;
        errBan.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
  });
})();
</script>

<style>
/* hidden attribute must not be overridden by display:flex rules */
[hidden] { display: none !important; }

/* ── Layout ──────────────────────────────────────────────── */
.contact-grid { display:grid; grid-template-columns:1fr 1fr; gap:3rem; }
.contact-form { display:flex; flex-direction:column; gap:1rem; }
.form-row     { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.form-field   { display:flex; flex-direction:column; gap:.3rem; }

/* ── Labels & inputs ─────────────────────────────────────── */
.contact-form label {
  font-size:.78rem; font-weight:700; letter-spacing:.06em;
  text-transform:uppercase; color:var(--ink); opacity:.6; display:block;
}
.contact-form input,
.contact-form select,
.contact-form textarea {
  width:100%; padding:.75rem 1rem;
  border:1.5px solid oklch(0.80 0.015 244);
  border-radius:var(--radius);
  background:#fff; font-family:inherit; font-size:.95rem;
  color:var(--ink); outline:none; transition:border-color .18s, box-shadow .18s;
}
.contact-form input:focus,
.contact-form select:focus,
.contact-form textarea:focus {
  border-color:var(--primary);
  box-shadow:0 0 0 3px oklch(0.42 0.14 242 / .12);
}
.contact-form input.input-invalid,
.contact-form select.input-invalid,
.contact-form textarea.input-invalid {
  border-color:oklch(0.55 0.20 20);
}
.contact-form textarea { min-height:130px; resize:vertical; }

/* ── Inline field errors ─────────────────────────────────── */
.field-error {
  font-size:.75rem; color:oklch(0.45 0.20 20);
  min-height:1em; display:block;
}

/* ── Feedback banners ────────────────────────────────────── */
.form-success {
  display:flex; align-items:center; gap:.65rem;
  padding:.9rem 1.2rem;
  background:oklch(0.96 0.06 145); border:1px solid oklch(0.78 0.12 145);
  border-radius:var(--radius); color:oklch(0.28 0.14 145);
  font-size:.9rem; font-weight:600;
}
.form-success svg { flex-shrink:0; stroke:oklch(0.38 0.18 145); }
.form-error-banner {
  padding:.9rem 1.2rem;
  background:oklch(0.97 0.04 20); border:1px solid oklch(0.82 0.12 20);
  border-radius:var(--radius); color:oklch(0.38 0.18 20); font-size:.9rem;
}
.form-error-banner a { color:inherit; font-weight:700; }

/* ── Contact info ────────────────────────────────────────── */
.contact-info-block { display:flex; flex-direction:column; gap:1.5rem; }
.info-item  { display:flex; gap:1rem; align-items:flex-start; }
.info-icon  { width:40px; height:40px; border-radius:50%; background:oklch(0.92 0.04 242); display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:1.1rem; }
.info-text h4 { font-size:.95rem; font-weight:700; color:var(--ink); margin:0 0 .25rem; }
.info-text p, .info-text a { font-size:.9rem; color:var(--ink); opacity:.7; margin:0; text-decoration:none; line-height:1.5; }
.info-text a:hover { color:var(--primary); opacity:1; }
.map-embed { width:100%; margin-top:1.5rem; border-radius:var(--radius); overflow:hidden; line-height:0; }

/* ── Dept cards ──────────────────────────────────────────── */
.dept-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; margin-top:2rem; }
.dept-card { padding:1.5rem; border:1px solid oklch(0.88 0.015 244); border-radius:var(--radius); }
.dept-card h4 { font-size:.95rem; font-weight:700; color:var(--primary); margin:0 0 .5rem; }
.dept-card p  { font-size:.85rem; color:var(--ink); opacity:.7; margin:0 0 .25rem; line-height:1.5; }
.dept-card a  { color:var(--primary); text-decoration:none; }
.dept-card a:hover { text-decoration:underline; }

/* ── Word count ──────────────────────────────────────────────── */
.msg-meta     { display:flex; justify-content:space-between; align-items:flex-start; gap:.5rem; min-height:1em; }
.word-count   { font-size:.75rem; color:var(--ink); opacity:.45; white-space:nowrap; flex-shrink:0; }
.word-count.over-limit { color:oklch(0.45 0.20 20); opacity:1; font-weight:600; }

/* ── Submit button states ────────────────────────────────────── */
#cf-submit.btn-state-success { background:oklch(0.42 0.14 145); }
#cf-submit.btn-state-error   { background:oklch(0.45 0.18 20); }

@media(max-width:768px) {
  .contact-grid { grid-template-columns:1fr; }
  .form-row     { grid-template-columns:1fr; }
  .dept-grid    { grid-template-columns:1fr; }
}
</style>
