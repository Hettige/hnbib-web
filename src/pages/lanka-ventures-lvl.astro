---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Lanka Ventures / LVL Energy Fund — HNB Investment Bank"
  description="Two CSE-listed funds managed by HNB Investment Bank — Lanka Ventures, Sri Lanka's pioneer venture capital vehicle, and LVL Energy Fund, focused on the energy sector."
>

<div class="page-header"><div class="page-header-inner">
  <div class="page-header-eyebrow">Lanka Ventures PLC · LVL Energy Fund PLC</div>
  <h1 class="page-header-h1">Venture capital and energy investment since 1992.</h1>
  <p class="page-header-lead">Two CSE-listed funds managed by HNB Investment Bank — Lanka Ventures, Sri Lanka's pioneer venture capital vehicle, and LVL Energy Fund, focused on the energy sector.</p>
</div></div>

<main class="page-body">

<!-- S1: Heritage story -->
<section class="section-host" data-section-id="s1-heritage" data-section-label="Heritage">
  <div class="variant section-toggle-active" data-variant="B" data-variant-label="Middle">
    <div class="section-pad" style="background:var(--bg-2)"><div class="section-inner">
      <div class="section-header reveal"><div class="section-eyebrow">Our Story</div><h2 class="section-h2">From venture capital to energy — a 30-year evolution.</h2></div>
      <div style="display:flex;align-items:stretch;gap:0;overflow-x:auto;padding-bottom:12px" class="reveal">
        <div style="flex:1;min-width:180px;padding:var(--sp-m);background:var(--card);border:1px solid var(--line);border-radius:var(--radius) 0 0 var(--radius)"><div style="font-size:40px;font-weight:800;color:var(--primary);margin-bottom:8px">1992</div><div style="font-weight:700;color:var(--ink);margin-bottom:6px">Incorporated</div><div style="font-size:13px;color:var(--ink-2)">Lanka Ventures PLC established as Sri Lanka's first institutional VC fund.</div></div>
        <div style="flex:1;min-width:180px;padding:var(--sp-m);background:var(--bg);border:1px solid var(--line);border-left:none"><div style="font-size:40px;font-weight:800;color:var(--primary);margin-bottom:8px">1995</div><div style="font-weight:700;color:var(--ink);margin-bottom:6px">CSE Listing</div><div style="font-size:13px;color:var(--ink-2)">Lanka Ventures listed on the Colombo Stock Exchange.</div></div>
        <div style="flex:1;min-width:180px;padding:var(--sp-m);background:var(--bg);border:1px solid var(--line);border-left:none"><div style="font-size:40px;font-weight:800;color:var(--accent-d);margin-bottom:8px">2006</div><div style="font-weight:700;color:var(--ink);margin-bottom:6px">Energy Pivot</div><div style="font-size:13px;color:var(--ink-2)">Strategic shift to energy investments. LVL Energy Fund PLC launched.</div></div>
        <div style="flex:1;min-width:180px;padding:var(--sp-m);background:var(--primary);border-radius:0 var(--radius) var(--radius) 0"><div style="font-size:40px;font-weight:800;color:oklch(1 0 0/.25);margin-bottom:8px">Now</div><div style="font-weight:700;color:#fff;margin-bottom:6px">Dual Funds</div><div style="font-size:13px;color:oklch(1 0 0/.65)">Two CSE-listed funds managed by HNB Investment Bank.</div></div>
      </div>
    </div></div>
  </div>
</section>

<!-- S2: Investment focus -->
<section class="section-host" data-section-id="s2-funds" data-section-label="Funds">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Simple">
    <div class="section-pad" style="background:var(--bg-2)"><div class="section-inner">
      <div class="section-header reveal"><div class="section-eyebrow">The Funds</div><h2 class="section-h2">Two vehicles. One manager.</h2></div>
      <div class="grid-2">
        <div class="fund-card reveal">
          <div class="fund-card-tag">CSE Listed · Venture Capital</div>
          <div class="fund-card-name">Lanka Ventures PLC</div>
          <div class="fund-card-year">1992</div>
          <div class="fund-card-desc">Sri Lanka's pioneer institutionally-backed venture capital fund. Listed on the CSE since 1995. Provides growth capital to early and mid-stage Sri Lankan enterprises.</div>
          <a href={`${base}investor-relations/`} class="btn-ghost" style="align-self:flex-start;font-size:13px;padding:8px 16px">Investor info →</a>
        </div>
        <div class="fund-card reveal" style="border-top:3px solid var(--accent)">
          <div class="fund-card-tag" style="color:var(--accent-d)">CSE Listed · Energy</div>
          <div class="fund-card-name">LVL Energy Fund PLC</div>
          <div class="fund-card-year" style="color:var(--accent-d)">2006</div>
          <div class="fund-card-desc">Launched following the 2006 energy sector pivot, LVL Energy Fund focuses on renewable and conventional energy investments across Sri Lanka. Separately listed on the CSE.</div>
          <a href={`${base}investor-relations/`} class="btn-ghost" style="align-self:flex-start;font-size:13px;padding:8px 16px;border-color:var(--accent);color:var(--accent-d)">Investor info →</a>
        </div>
      </div>
    </div></div>
  </div>
</section>

<div class="cta-final"><div class="cta-final-inner">
  <h2 class="cta-final-h2 reveal">Investor enquiries welcome.</h2>
  <p class="cta-final-sub reveal">For fund information, shareholder queries, or investment opportunities in Lanka Ventures or LVL Energy Fund, contact our Investor Relations team.</p>
  <div class="cta-final-btns reveal">
    <a href={`${base}investor-relations/`} class="btn-white">Investor Relations</a>
    <a href={`${base}contact-us/`} class="btn-ghost-white">Contact Us →</a>
  </div>
  <div class="cta-trust reveal"><span>CSE Listed</span><span class="dot">·</span><span>HNB Investment Bank managed</span><span class="dot">·</span><span>Since 1992</span></div>
</div></div>

</main>

</BaseLayout>

<style>
.fund-card { background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:var(--sp-m); display:flex; flex-direction:column; gap:12px; }
.fund-card-tag { font-size:10px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:var(--primary); }
.fund-card-name { font-size:22px; font-weight:800; color:var(--ink); }
.fund-card-year { font-size:36px; font-weight:800; color:var(--primary); }
.fund-card-desc { font-size:13px; color:var(--ink-2); line-height:1.55; flex:1; }
</style>
