---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Investor Relations — HNB Investment Bank"
  description="Annual reports, share information, registered office details, and direct access to our IR team."
>

<div class="page-header"><div class="page-header-inner">
  <div class="page-header-eyebrow">Investor Relations</div>
  <h1 class="page-header-h1">Transparency for our shareholders and partners.</h1>
  <p class="page-header-lead">Annual reports, share information, registered office details, and direct access to our IR team — everything you need to stay informed.</p>
</div></div>

<main class="page-body">

<!-- S1: Annual Reports (Variant B active — features latest prominently) -->
<section class="section-host" data-section-id="s1-reports" data-section-label="Reports">
  <div class="variant section-toggle-active" data-variant="B" data-variant-label="Middle">
    <div class="section-pad" style="background:var(--bg-2)"><div class="section-inner">
      <div class="section-header reveal"><div class="section-eyebrow">Annual Reports</div><h2 class="section-h2">Our financial track record — open and published.</h2></div>
      <div style="display:grid;grid-template-columns:3fr 2fr;gap:var(--sp-l);align-items:start">
        <div class="reveal">
          <div class="card card-p" style="border-top:3px solid var(--primary);margin-bottom:16px">
            <div style="font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--primary);margin-bottom:8px">Latest · 2022/23</div>
            <div style="font-size:22px;font-weight:800;color:var(--ink)">Annual Report 2022/23</div>
            <div style="font-size:14px;color:var(--ink-2);margin-top:8px;line-height:1.5">Audited financial statements for the year ended 31 December 2022. Includes consolidated accounts, director's report, and independent auditor's report.</div>
            <a href="#" class="btn-primary" style="margin-top:16px;align-self:flex-start">Download PDF →</a>
          </div>
          <div style="display:flex;flex-direction:column;gap:8px">
            <a href="#" class="report-card"><div class="report-icon">PDF</div><div><div class="report-year">2021/22</div><div class="report-title">Annual Report — Audited Financial Statements</div></div><span class="report-dl">Download →</span></a>
            <a href="#" class="report-card"><div class="report-icon">PDF</div><div><div class="report-year">2020/21</div><div class="report-title">Annual Report — Audited Financial Statements</div></div><span class="report-dl">Download →</span></a>
            <a href="#" class="report-card"><div class="report-icon">PDF</div><div><div class="report-year">2019/20</div><div class="report-title">Annual Report — Audited Financial Statements</div></div><span class="report-dl">Download →</span></a>
          </div>
        </div>
        <div class="reveal" style="display:flex;flex-direction:column;gap:12px">
          <div class="ir-contact-card"><div class="ir-label">Company Reg. No.</div><div class="ir-value">PV 62973</div></div>
          <div class="ir-contact-card"><div class="ir-label">Registered Office</div><div class="ir-value">No. 53, Dharmapala Mawatha, Colombo 03</div></div>
          <div class="ir-contact-card"><div class="ir-label">Telephone</div><div class="ir-value">+94 112 206 206</div></div>
          <div class="ir-contact-card"><div class="ir-label">CSE Listing</div><div class="ir-value">Colombo Stock Exchange</div></div>
          <div class="ir-contact-card"><div class="ir-label">Parent Company</div><div class="ir-value">Hatton National Bank PLC</div></div>
        </div>
      </div>
    </div></div>
  </div>
</section>

<!-- S2: Share info + contacts (Variant A active) -->
<section class="section-host" data-section-id="s2-share-info" data-section-label="Share Info">
  <div class="variant section-toggle-active" data-variant="A" data-variant-label="Simple">
    <div class="section-pad" style="background:var(--bg-2)"><div class="section-inner">
      <div class="section-header reveal"><div class="section-eyebrow">Company Information</div><h2 class="section-h2">Share information &amp; IR contacts.</h2></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-l)">
        <div class="reveal">
          <h3 style="font-size:16px;font-weight:700;color:var(--ink);margin-bottom:16px">Company Details</h3>
          <table class="proto-table"><tbody>
            <tr><td style="font-weight:600;color:var(--ink-2)">Company Name</td><td>HNB Investment Bank Limited</td></tr>
            <tr><td style="font-weight:600;color:var(--ink-2)">Reg. Number</td><td>PV 62973</td></tr>
            <tr><td style="font-weight:600;color:var(--ink-2)">Reg. Office</td><td>No. 53, Dharmapala Mawatha, Colombo 03</td></tr>
            <tr><td style="font-weight:600;color:var(--ink-2)">Head Office</td><td>No. 479, T.B. Jayah Mawatha, Colombo 10</td></tr>
            <tr><td style="font-weight:600;color:var(--ink-2)">Telephone</td><td>+94 112 206 206</td></tr>
            <tr><td style="font-weight:600;color:var(--ink-2)">Exchange</td><td>Colombo Stock Exchange (CSE)</td></tr>
            <tr><td style="font-weight:600;color:var(--ink-2)">Parent</td><td>Hatton National Bank PLC</td></tr>
          </tbody></table>
        </div>
        <div class="reveal">
          <h3 style="font-size:16px;font-weight:700;color:var(--ink);margin-bottom:16px">IR Contact</h3>
          <div class="ir-contact-card" style="margin-bottom:12px"><div class="ir-label">Investor Relations</div><div class="ir-value">HNB Investment Bank Limited</div><div style="font-size:13px;color:var(--ink-2);margin-top:4px">No. 53, Dharmapala Mawatha, Colombo 03</div></div>
          <div class="ir-contact-card" style="margin-bottom:12px"><div class="ir-label">Telephone</div><div class="ir-value">+94 112 206 206</div></div>
          <div class="ir-contact-card" style="margin-bottom:12px"><div class="ir-label">Email</div><div class="ir-value"><a href="mailto:ir@hnbib.lk" style="color:var(--primary);text-decoration:none;">ir@hnbib.lk</a></div></div>
          <a href={`${base}contact-us/`} class="btn-primary">Contact IR Team →</a>
        </div>
      </div>
    </div></div>
  </div>
</section>

<div class="cta-final"><div class="cta-final-inner">
  <h2 class="cta-final-h2 reveal">Have an IR enquiry?</h2>
  <p class="cta-final-sub reveal">Contact our Investor Relations team at +94 112 206 206 or through our online form.</p>
  <div class="cta-final-btns reveal">
    <a href={`${base}contact-us/`} class="btn-white">Contact IR Team</a>
    <a href="#" class="btn-ghost-white">Download Latest Report →</a>
  </div>
</div></div>

</main>

</BaseLayout>

<style>
.report-card { background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:var(--sp-m); display:flex; align-items:center; gap:16px; transition:box-shadow .18s; text-decoration:none; color:inherit; }
.report-card:hover { box-shadow:0 6px 20px oklch(0.42 0.14 242/.10); }
.report-icon { width:48px; height:60px; background:var(--primary); border-radius:4px; flex-shrink:0; display:flex; align-items:center; justify-content:center; color:#fff; font-size:11px; font-weight:700; letter-spacing:.06em; }
.report-year { font-size:18px; font-weight:800; color:var(--ink); }
.report-title { font-size:13px; color:var(--ink-2); margin-top:2px; }
.report-dl { font-size:12px; font-weight:700; color:var(--primary); margin-left:auto; white-space:nowrap; }
.ir-contact-card { background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:var(--sp-m); }
.ir-label { font-size:10px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:var(--ink-3); margin-bottom:6px; }
.ir-value { font-size:16px; font-weight:700; color:var(--ink); }
@media (max-width:768px) {
  div[style*="grid-template-columns:3fr 2fr"] { grid-template-columns:1fr !important; }
  div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns:1fr !important; }
}
</style>
